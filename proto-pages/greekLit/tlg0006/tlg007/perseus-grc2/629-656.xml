<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0006.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0006.tlg007.perseus-grc2:629-656" prev_urn="urn:cts:greekLit:tlg0006.tlg007.perseus-grc2:484-628" next_urn="urn:cts:greekLit:tlg0006.tlg007.perseus-grc2:658-904">
  <elements><tei:div type="choral">
            <tei:div type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="629">ἐμοὶ χρῆν συμφοράν,</tei:l>
                  <tei:l n="630">ἐμοὶ χρῆν πημονὰν γενέσθαι,</tei:l>
                  <tei:l n="631">Ἰδαίαν ὅτε πρῶτον ὕλαν</tei:l>
                  <tei:l n="632">Ἀλέξανδρος εἰλατίναν</tei:l>
                  <tei:l n="633">ἐτάμεθʼ, ἅλιον ἐπʼ οἶδμα ναυστολήσων</tei:l>
                  <tei:l n="635">Ἑλένας ἐπὶ λέκτρα, τὰν</tei:l>
                  <tei:l n="636">καλλίσταν ὁ χρυσοφαὴς</tei:l>
                  <tei:l n="637">Ἅλιος αὐγάζει.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone resp="perseus" n="638" unit="card"/>
            <tei:div type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="639">πόνοι γὰρ καὶ πόνων</tei:l>
                  <tei:l n="640">ἀνάγκαι κρείσσονες κυκλοῦνται</tei:l>
                  <tei:l n="641">κοινὸν δʼ ἐξ ἰδίας ἀνοίας</tei:l>
                  <tei:l n="642">κακὸν τᾷ Σιμουντίδι γᾷ</tei:l>
                  <tei:l n="643">ὀλέθριον ἔμολε συμφορά τʼ ἀπʼ ἄλλων.</tei:l>
                  <tei:l n="644">ἐκρίθη δʼ ἔρις, ἃν ἐν Ἴ-</tei:l>
                  <tei:l n="645">δᾳ κρίνει τρισσὰς μακάρων</tei:l>
                  <tei:l n="646">παῖδας ἀνὴρ βούτας,</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone resp="perseus" n="648" unit="card"/>
            <tei:div type="epode">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="648">ἐπὶ δορὶ καὶ φόνῳ καὶ ἐμῶν μελάθρων λώβᾳ·</tei:l>
                  <tei:l n="650">στένει δὲ καί τις ἀμφὶ τὸν εὔροον Εὐρώταν</tei:l>
                  <tei:l n="651">Λάκαινα πολυδάκρυτος ἐν δόμοις κόρα,</tei:l>
                  <tei:l n="653">πολιάν τʼ ἐπὶ κρᾶτα μάτηρ</tei:l>
                  <tei:l n="654">τέκνων θανόντων</tei:l>
                  <tei:l n="655">
                     <tei:sic>τίθεται χέρα δρύπτεται παρειάν,</tei:sic>
                  </tei:l>
                  <tei:l n="656">δίαιμον ὄνυχα τιθεμένα σπαραγμοῖς.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
