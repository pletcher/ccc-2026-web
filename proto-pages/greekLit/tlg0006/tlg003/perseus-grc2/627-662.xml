<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0006.tlg003.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0006.tlg003.perseus-grc2:627-662" prev_urn="urn:cts:greekLit:tlg0006.tlg003.perseus-grc2:446-626" next_urn="urn:cts:greekLit:tlg0006.tlg003.perseus-grc2:663-823">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="627">ἔρωτες ὑπὲρ μὲν ἄγαν</tei:l>
                  <tei:l n="628">ἐλθόντες οὐκ εὐδοξίαν</tei:l>
                  <tei:l n="629">οὐδ’ ἀρετὰν παρέδωκαν</tei:l>
                  <tei:pb facs="euripidisfabulae01euriuoft_0130"/>
                  <tei:l n="630">ἀνδράσιν· εἰ δ’ ἅλις ἔλθοι</tei:l>
                  <tei:l n="631">Κύπρις, οὐκ ἄλλα θεὸς εὔχαρις οὕτως.</tei:l>
                  <tei:l n="632">μήποτ’, ὦ δέσποιν’, ἐπ’ ἐμοὶ χρυσέων τόξων ἐφείης</tei:l>
                  <tei:l n="633">ἱμέρῳ χρίσασ’ ἄφυκτον οἰστόν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="635" unit="card" resp="perseus"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="635">στέργοι δέ με σωφροσύνα,</tei:l>
                  <tei:l n="636">δώρημα κάλλιστον θεῶν·</tei:l>
                  <tei:l n="637">μηδέ ποτ’ ἀμφιλόγους ὀργὰς</tei:l>
                  <tei:l n="638">ἀκόρεστά τε νείκη</tei:l>
                  <tei:l n="639">θυμὸν ἐκπλήξασ’ ἑτέροις ἐπὶ λέκτροις</tei:l>
                  <tei:l n="640">προσβάλοι δεινὰ Κύπρις, ἀπτολέμους δ’ εὐνὰς σεβίζουσ’</tei:l>
                  <tei:l n="641">ὀξύφρων κρίνοι λέχη γυναικῶν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="643" unit="card" resp="perseus"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="643">ὦ πατρίς, ὦ δώματα, μὴ</tei:l>
                  <tei:l n="644">δῆτ’ ἄπολις γενοίμαν</tei:l>
                  <tei:l n="645">τὸν ἀμηχανίας ἔχουσα</tei:l>
                  <tei:l n="646">δυσπέρατον αἰῶν’,</tei:l>
                  <tei:l n="647">οἰκτροτάτων ἀχέων.</tei:l>
                  <tei:l n="648">θανάτῳ θανάτῳ πάρος δαμείην</tei:l>
                  <tei:l n="649">ἁμέραν τάνδ’ ἐξανύσασα· μό-</tei:l>
                  <tei:l n="650">χθων δ’ οὐκ ἄλλος ὕπερθεν ἢ</tei:l>
                  <tei:l n="651">γᾶς πατρίας στέρεσθαι.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="652" unit="card" resp="perseus"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="652">εἴδομεν, οὐκ ἐξ ἑτέρων</tei:l>
                  <tei:l n="653">μῦθον ἔχω φράσασθαι·</tei:l>
                  <tei:pb facs="euripidisfabulae01euriuoft_0131"/>
                  <tei:l n="655">σὲ γὰρ οὐ πόλις, οὐ φίλων τις</tei:l>
                  <tei:l n="656">ᾤκτισεν παθοῦσαν</tei:l>
                  <tei:l n="657">δεινότατον παθέων.</tei:l>
                  <tei:l n="658">ἀχάριστος ὄλοιθ’, ὅτῳ πάρεστιν</tei:l>
                  <tei:l n="660">μὴ φίλους τιμᾶν καθαρᾶν ἀνοί-</tei:l>
                  <tei:l n="661">ξαντα κλῇδα φρενῶν· ἐμοὶ</tei:l>
                  <tei:l n="662">μὲν φίλος οὔποτ’ ἔσται.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
