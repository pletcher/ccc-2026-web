<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg004.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg004.perseus-grc2:822-956" prev_urn="urn:cts:greekLit:tlg0085.tlg004.perseus-grc2:792-821" next_urn="urn:cts:greekLit:tlg0085.tlg004.perseus-grc2:957-965">
  <elements><tei:div type="choral">
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="822">ὦ μεγάλε Ζεῦ καὶ πολιοῦχοι</tei:l>
                  <tei:l n="823">δαίμονες, οἳ δὴ Κάδμου πύργους</tei:l>
                  <tei:l n="824">τούσδε ῥύεσθε,</tei:l>
                  <tei:l n="825">πότερον χαίρω κἀπολολύξω</tei:l>
                  <tei:l n="826">πόλεως ἀσινεῖ <tei:sic>σωτῆρι</tei:sic> . .,</tei:l>
                  <tei:l n="827">ἢ τοὺς μογεροὺς καὶ δυσδαίμονας</tei:l>
                  <tei:l n="830">ἀτέκνους κλαύσω πολεμάρχους;</tei:l>
                  <tei:l n="831">οἳ δῆτʼ ὀρθῶς κατʼ ἐπωνυμίαν</tei:l>
                  <tei:l n="832">καὶ πολυνεικεῖς</tei:l>
                  <tei:l n="832b">ὤλοντʼ ἀσεβεῖ διανοίᾳ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="833" unit="card"/>
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="833">ὦ μέλαινα καὶ τελεία</tei:l>
                  <tei:l n="833b">γένεος Οἰδίπου τʼ ἀρά,</tei:l>
                  <tei:l n="834">κακόν με καρδίαν τι περιπίτνει κρύος.</tei:l>
                  <tei:l n="835">ἔτευξα τύμβῳ μέλος</tei:l>
                  <tei:l n="836">Θυιὰς αἱματοσταγεῖς</tei:l>
                  <tei:l n="837">νεκροὺς κλύουσα δυσμόρως</tei:l>
                  <tei:l n="838">θανόντας· ἦ δύσορνις ἅ-</tei:l>
                  <tei:l n="839">δε ξυναυλία δορός.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="840" unit="card"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="840">ἐξέπραξεν, οὐδʼ ἀπεῖπεν</tei:l>
                  <tei:l n="841">πατρόθεν εὐκταία φάτις·</tei:l>
                  <tei:l n="842">βουλαὶ δʼ ἄπιστοι Λαΐου διήρκεσαν.</tei:l>
                  <tei:l n="843">μέριμνα δʼ ἀμφὶ πτόλιν·</tei:l>
                  <tei:l n="844">θέσφατʼ οὐκ ἀμβλύνεται.</tei:l>
                  <tei:l n="845">ἰὼ πολύστονοι, τόδʼ ἠρ-</tei:l>
                  <tei:l n="846">γάσασθʼ ἄπιστον· ἦλθε δʼ αἰ-</tei:l>
                  <tei:l n="847">ακτὰ πήματʼ οὐ λόγῳ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="848" unit="card"/>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="848">τάδʼ αὐτόδηλα, προῦπτος ἀγγέλου λόγος·</tei:l>
                  <tei:l n="849">διπλαῖ μέριμναι, <tei:sic>διδυμάνορα</tei:sic>
                  </tei:l>
                  <tei:l n="850">κάκʼ αὐτοφόνα, δίμοιρα τέ-</tei:l>
                  <tei:l n="851">λεια τάδε πάθη. τί φῶ;</tei:l>
                  <tei:l n="852">τί δʼ ἄλλο γʼ ἢ πόνοι πόνων</tei:l>
                  <tei:l n="853">δόμων ἐφέστιοι;</tei:l>
                  <tei:l n="854">ἀλλὰ γόων, ὦ φίλαι, κατʼ οὖρον</tei:l>
                  <tei:l n="855">ἐρέσσετʼ ἀμφὶ κρατὶ πόμπιμον χεροῖν</tei:l>
                  <tei:l n="856">πίτυλον, ὃς αἰὲν διʼ Ἀχέροντʼ ἀμείβεται</tei:l>
                  <tei:l n="857">τὰν ἄστολον μελάγκροκον <tei:del>ναύστολον</tei:del> θεωρίδα,</tei:l>
                  <tei:l n="858">τὰν ἀστιβῆ Ἀπόλλωνι, τὰν ἀνάλιον</tei:l>
                  <tei:l n="860">πάνδοκον εἰς ἀφανῆ τε χέρσον.</tei:l>
                  <tei:l n="861">ἀλλὰ γὰρ ἥκουσʼ αἵδʼ ἐπὶ πρᾶγος</tei:l>
                  <tei:l n="862">πικρὸν Ἀντιγόνη τʼ ἠδʼ Ἰσμήνη,</tei:l>
                  <tei:l n="863">θρῆνον ἀδελφοῖν· οὐκ ἀμφιβόλως</tei:l>
                  <tei:l n="864">οἶμαί σφʼ ἐρατῶν ἐκ βαθυκόλπων</tei:l>
                  <tei:l n="865">στηθέων ἥσειν ἄλγος ἐπάξιον.</tei:l>
                  <tei:l n="866">ἡμᾶς δὲ δίκη πρότερον φήμης</tei:l>
                  <tei:l n="867">τὸν δυσκέλαδόν θʼ ὕμνον Ἐρινύος</tei:l>
                  <tei:l n="868">ἰαχεῖν Ἀίδα τʼ</tei:l>
                  <tei:l n="870">ἐχθρὸν παιᾶνʼ ἐπιμέλπειν.</tei:l>
                  <tei:l n="871">ἰώ, δυσαδελφόταται πασῶν ὁπόσαι</tei:l>
                  <tei:l n="872">στρόφον ἐσθῆσιν περιβάλλονται,</tei:l>
                  <tei:l n="873">κλαίω, στένομαι, καὶ δόλος οὐδεὶς</tei:l>
                  <tei:l n="874">μὴ ʼκ φρενὸς ὀρθῶς με λιγαίνειν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="875" unit="card"/>
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="875">ἰὼ ἰὼ δύσφρονες,</tei:l>
                  <tei:l n="876">φίλων ἄπιστοι καὶ κακῶν ἀτρύμονες,</tei:l>
                  <tei:l n="877">δόμους πατρῴους ἑλόν-</tei:l>
                  <tei:l n="878">τες μέλεοι σὺν αἰχμᾷ.</tei:l>
                  <tei:l n="879">μέλεοι δῆθʼ οἳ μελέους θανάτους</tei:l>
                  <tei:l n="880">εὕροντο δόμων ἐπὶ λύμῃ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="881" unit="card"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="881">ἰὼ ἰὼ δωμάτων</tei:l>
                  <tei:l n="882">ἐρειψίτοιχοι καὶ πικρὰς μοναρχίας</tei:l>
                  <tei:l n="883">ἰδόντες, ἤδη διήλ-</tei:l>
                  <tei:l n="885">λαχθε σὺν σιδάρῳ.</tei:l>
                  <tei:l n="886">κάρτα δʼ ἀληθῆ πατρὸς Οἰδιπόδα</tei:l>
                  <tei:l n="887">πότνιʼ Ἐρινὺς ἐπέκρανεν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="888" unit="card"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="888">διʼ εὐωνύμων τετυμμένοι,</tei:l>
                  <tei:l n="889">τετυμμένοι δῆθʼ,</tei:l>
                  <tei:l n="890">ὁμοσπλάγχνων τε πλευρωμάτων</tei:l>
                  <tei:l n="891">
                     <tei:gap reason="lost"/>
                  </tei:l>
                  <tei:l n="892">αἰαῖ δαιμόνιοι,</tei:l>
                  <tei:l n="893">αἰαῖ δʼ ἀντιφόνων</tei:l>
                  <tei:l n="894">θανάτων ἀραί.</tei:l>
                  <tei:l n="895">διανταίαν λέγεις <tei:del>πλαγὰν</tei:del> δόμοισι καὶ</tei:l>
                  <tei:l n="896">σώμασιν πεπλαγμένους, <tei:del>ἐννέπω</tei:del>
                  </tei:l>
                  <tei:l n="897">ἀναυδάτῳ μένει</tei:l>
                  <tei:l n="898">ἀραίῳ τʼ ἐκ πατρὸς</tei:l>
                  <tei:l n="899">
                     <tei:add>οὐ</tei:add> διχόφρονι πότμῳ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="900" unit="card"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="900">διήκει δὲ καὶ πόλιν στόνος,</tei:l>
                  <tei:l n="901">στένουσι πύργοι,</tei:l>
                  <tei:l n="902">στένει πέδον φίλανδρον· μένει</tei:l>
                  <tei:l n="903">κτέανα δʼ ἐπιγόνοις,</tei:l>
                  <tei:l n="904">διʼ ὧν αἰνομόροις,</tei:l>
                  <tei:l n="905">διʼ ὧν νεῖκος ἔβα</tei:l>
                  <tei:l n="906">
                     <tei:del>καὶ</tei:del> θανάτου τέλος.</tei:l>
                  <tei:l n="907">ἐμοιράσαντο δʼ ὀξυκάρδιοι</tei:l>
                  <tei:l n="908">κτήμαθʼ, ὥστʼ ἴσον λαχεῖν.</tei:l>
                  <tei:l n="909">διαλλακτῆρι δʼ οὐκ</tei:l>
                  <tei:l n="909b">ἀμεμφεία φίλοις,</tei:l>
                  <tei:l n="910">οὐδʼ ἐπίχαρις Ἄρης.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="911" unit="card"/>
            <tei:div n="3" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="911">σιδαρόπλακτοι μὲν ὧδʼ ἔχουσιν,</tei:l>
                  <tei:l n="912">σιδαρόπλακτοι δὲ τοὺς μένουσι,</tei:l>
                  <tei:l n="913">τάχʼ ἄν τις εἴποι, τίνες;</tei:l>
                  <tei:l n="914">τάφων πατρῴων λαχαί.</tei:l>
                  <tei:l n="915">ὅδʼ ἁμῶν μάλʼ ἀχέτας τοὺς</tei:l>
                  <tei:l n="916">προπέμπει δαϊκτὴρ γόος αὐ-</tei:l>
                  <tei:l n="917">τόστονος, αὐτοπήμων,</tei:l>
                  <tei:l n="918">δαϊόφρων <tei:del>δʼ·</tei:del>, οὐ φιλογαθής, ἐτύμως</tei:l>
                  <tei:l n="919">δακρυχέων ἐκ φρενός, ἃ</tei:l>
                  <tei:l n="920">κλαιομένας μου μινύθει</tei:l>
                  <tei:l n="921">τοῖνδε δυοῖν ἀνάκτοιν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="922" unit="card"/>
            <tei:div n="3" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="922">πάρεστι δʼ εἰπεῖν ἐπʼ ἀθλίοισιν</tei:l>
                  <tei:l n="923">ὡς ἐρξάτην πολλὰ μὲν πολίτας,</tei:l>
                  <tei:l n="924">ξένων τε πάντων στίχας</tei:l>
                  <tei:l n="925">πολυφθόρους ἐν δαΐ.</tei:l>
                  <tei:l n="926">δυσδαίμων σφιν ἁ τεκοῦσα</tei:l>
                  <tei:l n="927">πρὸ πασᾶν γυναικῶν ὁπόσαι</tei:l>
                  <tei:l n="928">τεκνογόνοι κέκληνται.</tei:l>
                  <tei:l n="929">παῖδα τὸν αὑτᾶς πόσιν αὑτᾷ θεμένα</tei:l>
                  <tei:l n="930">τούσδʼ ἔτεχʼ, οἱ δʼ ὧδʼ ἐτελεύ-</tei:l>
                  <tei:l n="931">τασαν ὑπʼ ἀλλαλοφόνοις</tei:l>
                  <tei:l n="932">χερσὶν ὁμοσπόροισιν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="933" unit="card"/>
            <tei:div n="4" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="933">ὁμόσποροι δῆτα καὶ πανώλεθροι,</tei:l>
                  <tei:l n="934">διατομαῖς οὐ φίλοις,</tei:l>
                  <tei:l n="935">ἔριδι μαινομένᾳ,</tei:l>
                  <tei:l n="936">νείκεος ἐν τελευτᾷ.</tei:l>
                  <tei:l n="937">πέπαυται δʼ ἔχθος, ἐν δὲ γαίᾳ</tei:l>
                  <tei:l n="938">ζόα φονορύτῳ</tei:l>
                  <tei:l n="939">μέμεικται· κάρτα δʼ εἴσʼ ὅμαιμοι.</tei:l>
                  <tei:l n="940">πικρὸς λυτὴρ νεικέων ὁ πόντιος</tei:l>
                  <tei:l n="941">ξεῖνος ἐκ πυρὸς συθεὶς</tei:l>
                  <tei:l n="942">θακτὸς σίδαρος· πικρὸς δὲ χρημάτων</tei:l>
                  <tei:l n="943">κακὸς δατητὰς Ἄρης ἀρὰν πατρῴ-</tei:l>
                  <tei:l n="944">αν τιθεὶς ἀλαθῆ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="945" unit="card"/>
            <tei:div n="4" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="945">ἔχουσι μοῖραν λαχόντες οἱ μέλεοι</tei:l>
                  <tei:l n="946">διοδότων ἀχθέων·</tei:l>
                  <tei:l n="947">ὑπὸ δὲ σώματι γᾶς</tei:l>
                  <tei:l n="948">πλοῦτος ἄβυσσος ἔσται.</tei:l>
                  <tei:l n="949">ἰὼ πολλοῖς ἐπανθίσαντες</tei:l>
                  <tei:l n="950">πόνοισι γενεάν·</tei:l>
                  <tei:l n="951">τελευταῖαι δʼ ἐπηλάλαξαν</tei:l>
                  <tei:l n="952">Ἀραὶ τὸν ὀξὺν νόμον, τετραμμένου</tei:l>
                  <tei:l n="953">παντρόπῳ φυγᾷ γένους.</tei:l>
                  <tei:l n="954">ἕστακε δʼ Ἄτας τροπαῖον ἐν πύλαις,</tei:l>
                  <tei:l n="955">ἐν αἷς ἐθείνοντο, καὶ δυοῖν κρατή-</tei:l>
                  <tei:l n="956">σας ἔληξε δαίμων.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
