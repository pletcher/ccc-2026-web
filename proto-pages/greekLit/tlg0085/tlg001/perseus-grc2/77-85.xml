<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg001.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg001.perseus-grc2:77-85" prev_urn="urn:cts:greekLit:tlg0085.tlg001.perseus-grc2:68-76" next_urn="urn:cts:greekLit:tlg0085.tlg001.perseus-grc2:86-90">
  <elements><tei:div n="3" type="antistrophe">
            <tei:sp>
               <tei:speaker>Χορός</tei:speaker>
               <tei:l n="77">ἀλλά, θεοὶ γενέται</tei:l>
               <tei:l n="78">κλύετʼ εὖ τὸ δίκαιον ἰδόντες·</tei:l>
               <tei:l n="79">ἥβᾳ μὴ τέλεον</tei:l>
               <tei:l n="80">δόντες ἔχειν παρʼ αἶσαν,</tei:l>
               <tei:l n="81">ὕβριν δʼ ἑτοίμως στυγοῦντες,</tei:l>
               <tei:l n="82">πέλοιτʼ ἂν ἔνδικοι γάμοις.</tei:l>
               <tei:l n="83">ἔστι δὲ κἀκ πολέμου τειρομένοις</tei:l>
               <tei:l n="84">βωμὸς ἀρῆς φυγάσιν</tei:l>
               <tei:l n="85">ῥῦμα, δαιμόνων σέβας.</tei:l>
            </tei:sp>
         </tei:div>
         </elements>
