<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg001.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg001.perseus-grc2:49-57" prev_urn="urn:cts:greekLit:tlg0085.tlg001.perseus-grc2:40-48" next_urn="urn:cts:greekLit:tlg0085.tlg001.perseus-grc2:58-62">
  <elements><tei:div n="1" type="antistrophe">
            <tei:sp>
               <tei:speaker>Χορός</tei:speaker>
               <tei:l n="49">ὅντʼ ἐπιλεξαμένα,</tei:l>
               <tei:l n="50">νῦν ἐν ποιονόμοις</tei:l>
               <tei:l n="51">ματρὸς ἀρχαίας τόποις τῶν</tei:l>
               <tei:l n="52">πρόσθε πόνων μνασαμένα,</tei:l>
               <tei:l n="53">τά τε νῦν ἐπιδείξω</tei:l>
               <tei:l n="54">πιστὰ τεκμήρια γαιονόμοις,</tei:l>
               <tei:l n="55">τὰ δʼ ἄελπτά περ ὄντα φανεῖται.</tei:l>
               <tei:l n="56">γνώσεται</tei:l>
               <tei:l n="57">δὲ λόγους τις ἐν μάκει.</tei:l>
            </tei:sp>
         </tei:div>
         </elements>
