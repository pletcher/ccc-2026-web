  <elements><tei:div n="5" type="antistrophe">
            <tei:sp>
               <tei:speaker>Χορός</tei:speaker>
               <tei:l n="104">ἰδέσθω δʼ εἰς ὕβριν</tei:l>
               <tei:l n="105">βρότειον, οἵα νεάζει</tei:l>
               <tei:l n="106">πυθμὴν διʼ ἁ-</tei:l>
               <tei:l n="107">μὸν γάμον τεθαλὼς</tei:l>
               <tei:l n="108">δυσπαραβούλοισι φρεσίν,</tei:l>
               <tei:l n="109">καὶ διάνοιαν μαινόλιν</tei:l>
               <tei:l n="110">κέντρον ἔχων ἄφυκτον, ἄταν δʼ</tei:l>
               <tei:l n="111">ἀπάτᾳ μεταγνούς.</tei:l>
            </tei:sp>
