<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:201-213" prev_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:172-200" next_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:214-262">
  <elements><tei:div type="episode">
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Τέκμησσα</tei:speaker>
                  <tei:l n="201">ναὸς ἀρωγοὶ τῆς Αἴαντος,</tei:l>
                  <tei:l n="202">γενεᾶς χθονίων ἀπʼ Ἐρεχθειδῶν,</tei:l>
                  <tei:l n="203">ἔχομεν στοναχὰς οἱ κηδόμενοι</tei:l>
                  <tei:l n="204">τοῦ Τελαμῶνος τηλόθεν οἴκου.</tei:l>
                  <tei:l n="205">νῦν γὰρ ὁ δεινὸς μέγας ὠμοκρατὴς</tei:l>
                  <tei:l n="206">Αἴας θολερῷ</tei:l>
                  <tei:l n="207">κεῖται χειμῶνι νοσήσας.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="208">τί δʼ ἐνήλλακται τῆς ἡμερίας</tei:l>
                  <tei:l n="209">νὺξ ἥδε βάρος;</tei:l>
                  <tei:l n="210">παῖ τοῦ Φρυγίου Τελεύταντος,</tei:l>
                  <tei:l n="211">λέγʼ, ἐπεὶ σὲ λέχος δουριάλωτον</tei:l>
                  <tei:l n="212">στέρξας ἀνέχει θούριος Αἴας·</tei:l>
                  <tei:l n="213">ὥστʼ οὐκ ἂν ἄϊδρις ὑπείποις.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
