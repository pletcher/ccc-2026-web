<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:1185-1222" prev_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:961-1184" next_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:1223-1420">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1185">τίς ἄρα νέατος ἐς πότε λήξει πολυπλάγκτων ἐτέων ἀριθμός,</tei:l>
                  <tei:l n="1186">τὰν ἄπαυστον αἰὲν ἐμοὶ δορυσσοήτων</tei:l>
                  <tei:l n="1187">μόχθων ἄταν ἐπάγων</tei:l>
                  <tei:l n="1190">ἄν τὰν εὐρώδεα Τρωΐαν,</tei:l>
                  <tei:l n="1191">δύστανον ὄνειδος Ἑλλάνων;</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1192" resp="p"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1192">ὄφελε πρότερον αἰθέρα δῦναι μέγαν ἢ τὸν πολύκοινον Ἅιδαν</tei:l>
                  <tei:l n="1195">κεῖνος ἁνήρ, ὃς στυγερῶν ἔδειξεν ὅπλων</tei:l>
                  <tei:l n="1196">Ἕλλασιν κοινὸν Ἄρη.</tei:l>
                  <tei:l n="1197">ἰὼ πόνοι πρόγονοι πόνων·</tei:l>
                  <tei:l n="1198">κεῖνος γὰρ ἔπερσεν ἀνθρώπους.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1199" resp="p"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1199">ἐκεῖνος οὔτε στεφάνων</tei:l>
                  <tei:l n="1200">οὔτε βαθεῖαν κυλίκων</tei:l>
                  <tei:l n="1201">νεῖμεν ἐμοὶ τέρψιν ὁμιλεῖν,</tei:l>
                  <tei:l n="1202">οὔτε γλυκὺν αὐλῶν ὄτοβον,</tei:l>
                  <tei:l n="1203">δύσμορος, οὔτʼ ἐννυχίαν</tei:l>
                  <tei:l n="1204">τέρψιν ἰαύειν.</tei:l>
                  <tei:l n="1205">ἐρώτων δʼ ἐρώτων ἀπέπαυσεν, ὤμοι.</tei:l>
                  <tei:l n="1206">κεῖμαι δʼ, ἀμέριμνος οὕτως,</tei:l>
                  <tei:l n="1207">ἀεὶ πυκιναῖς δρόσοις</tei:l>
                  <tei:l n="1208">τεγγόμενος κόμας,</tei:l>
                  <tei:l n="1210">λυγρᾶς μνήματα Τροίας.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1211" resp="p"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1211">καὶ πρὶν μὲν αἰὲν νυχίου</tei:l>
                  <tei:l n="1212">δείματος ἦν μοι προβολὰ</tei:l>
                  <tei:l n="1213">καὶ βελέων θούριος Αἴας·</tei:l>
                  <tei:l n="1214">νῦν δʼ οὗτος ἀνεῖται στυγερῷ</tei:l>
                  <tei:l n="1215">δαίμονι· τίς μοι, τίς ἔτʼ οὖν</tei:l>
                  <tei:l n="1216">τέρψις ἐπέσται;</tei:l>
                  <tei:l n="1217">γενοίμαν ἵνʼ ὑλᾶεν ἔπεστι πόντου</tei:l>
                  <tei:l n="1218">πρόβλημʼ ἁλίκλυστον, ἄκραν</tei:l>
                  <tei:l n="1220">ὑπὸ πλάκα Σουνίου,</tei:l>
                  <tei:l n="1221">τὰς ἱερὰς ὅπως</tei:l>
                  <tei:l n="1222">προσείποιμεν Ἀθάνας.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
