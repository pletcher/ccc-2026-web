<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg001.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg001.perseus-grc2:947-971" prev_urn="urn:cts:greekLit:tlg0011.tlg001.perseus-grc2:863-946" next_urn="urn:cts:greekLit:tlg0011.tlg001.perseus-grc2:972-1003">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="947">πότερα πρότερον ἐπιστένω,</tei:l>
                  <tei:l n="948">πότερα μέλεα περαιτέρω,</tei:l>
                  <tei:l n="949">δύσκριτʼ ἔμοιγε δυστάνῳ.</tei:l>
               </tei:sp>
               <tei:milestone unit="card" n="950"/>
            </tei:div>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="950">τάδε μὲν ἔχομεν ὁρᾶν δόμοις,</tei:l>
                  <tei:l n="951">τάδε δὲ μένομεν ἐπʼ ἐλπίσιν·</tei:l>
                  <tei:l n="952">κοινὰ δʼ ἔχειν τε καὶ μέλλειν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="953"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="953">εἴθʼ ἀνεμόεσσά τις</tei:l>
                  <tei:l n="955">γένοιτʼ ἔπουρος ἑστιῶτις αὔρα,</tei:l>
                  <tei:l n="956">ἥτις μʼ ἀποικίσειεν ἐκ τόπων, ὅπως</tei:l>
                  <tei:l n="957">τὸν Δῖον ἄλκιμον γόνον</tei:l>
                  <tei:l n="960">μὴ ταρβαλέα θάνοιμι</tei:l>
                  <tei:l n="961">μοῦνον εἰσιδοῦσʼ ἄφαρ·</tei:l>
                  <tei:l n="962">ἐπεὶ ἐν δυσαπαλλάκτοις ὀδύναις</tei:l>
                  <tei:l n="963">χωρεῖν πρὸ δόμων λέγουσιν</tei:l>
                  <tei:l n="964">ἄσπετόν τι θαῦμα.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="965"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="965">ἀγχοῦ δʼ ἄρα κοὐ μακρὰν</tei:l>
                  <tei:l n="966">προύκλαιον, ὀξύφωνος ὡς ἀηδών.</tei:l>
                  <tei:l n="967">ξένων γὰρ ἐξόμιλος ἥδε τις βάσις.</tei:l>
                  <tei:l n="968">πᾷ δʼ αὖ φορεῖ νιν; ὡς φίλου</tei:l>
                  <tei:l n="969">προκηδομένα βαρεῖαν</tei:l>
                  <tei:l n="969a">ἄψοφον φέρει βάσιν.</tei:l>
                  <tei:l n="970">αἰαῖ, ὅδʼ ἀναύδατος φέρεται.</tei:l>
                  <tei:l n="970a">τί χρὴ θανόντα νιν ἢ καθʼ</tei:l>
                  <tei:l n="971">ὕπνον ὄντα κρῖναι;</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
