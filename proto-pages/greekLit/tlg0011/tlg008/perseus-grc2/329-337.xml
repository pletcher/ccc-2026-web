  <elements><tei:div type="card" n="329">
            <tei:sp>
               <tei:speaker>Χορός</tei:speaker>
               <tei:l n="329">ὀ<tei:add>ρθ</tei:add>οψάλακτός τις ὀμφὴ κατοιχνεῖ τόπου, <tei:note anchored="true" type="meter" place="inline">στρ.</tei:note>
               </tei:l>
               <tei:l n="330">πρεπτὰ <tei:add>δʼ αὖ</tei:add> διὰ τόνου φάσματʼ ἔγ-</tei:l>
               <tei:l n="331">χωρʼ ἐπανθεμίζει.</tei:l>
               <tei:l n="332">τὸ πρᾶγμα δʼ οὗπερ πορεύω βάδην,</tei:l>
               <tei:l n="333">ἴσθι τὸν δα[ί]μονʼ, ὅστις ποθʼ ὃς</tei:l>
               <tei:l n="334">ταῦτʼ ἐτεχνήσατʼ, οὐκ ἄλλος ἐστὶν κλ[οπεὺς</tei:l>
               <tei:l n="335">ἀντʼ ἐκείνου, γύναι, σάφʼ ἴσθι.</tei:l>
               <tei:l n="336">σὺ δʼ ἀντὶ τῶνδε μὴ χαλε-</tei:l>
               <tei:l n="337">φθῇς μ<tei:add>η</tei:add>δὲ δυσφορηθῇς. </tei:l>
            </tei:sp>
