<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1044-1097" prev_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:720-1043" next_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1098-1210">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1044">εἴην ὅθι δαΐων</tei:l>
                  <tei:l n="1045">ἀνδρῶν τάχʼ ἐπιστροφαὶ</tei:l>
                  <tei:l n="1046">τὸν χαλκοβόαν Ἄρη</tei:l>
                  <tei:l n="1047">μείξουσιν, ἢ πρὸς Πυθίαις</tei:l>
                  <tei:l n="1048">ἢ λαμπάσιν ἀκταῖς,</tei:l>
                  <tei:l n="1050">οὗ πότνιαι σεμνὰ τιθηνοῦνται τέλη</tei:l>
                  <tei:l n="1051">θνατοῖσιν, ὧν καὶ χρυσέα</tei:l>
                  <tei:l n="1052">κλῂς ἐπὶ γλώσσᾳ βέβακε</tei:l>
                  <tei:l n="1053">προσπόλων Εὐμολπιδᾶν·</tei:l>
                  <tei:l n="1054">ἔνθʼ οἶμαι τὸν ἐγρεμάχαν</tei:l>
                  <tei:l n="1055">Θησέα καὶ τὰς διστόλους</tei:l>
                  <tei:l n="1056">ἀδμῆτας ἀδελφὰς</tei:l>
                  <tei:l n="1057">αὐτάρκει τάχʼ ἐμμίξειν βοᾷ</tei:l>
                  <tei:l n="1058">τούσδʼ ἀνὰ χώρους·</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1059"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1059">ἤ που τὸν ἐφεσπέρου</tei:l>
                  <tei:l n="1060">πέτρας νιφάδος πελῶσʼ</tei:l>
                  <tei:l n="1061">Οἰάτιδος εἰς νόμον,</tei:l>
                  <tei:l n="1062">πώλοισιν ἢ ῥιμφαρμάτοις</tei:l>
                  <tei:l n="1063">φεύγοντες ἁμίλλαις.</tei:l>
                  <tei:l n="1065">ἁλώσεται· δεινὸς ὁ προσχώρων Ἄρης,</tei:l>
                  <tei:l n="1066">δεινὰ δὲ Θησειδᾶν ἀκμά.</tei:l>
                  <tei:l n="1067">πᾶς γὰρ ἀστράπτει χαλινός,</tei:l>
                  <tei:l n="1068">πᾶσα δʼ ὁρμᾶται καθεῖσʼ</tei:l>
                  <tei:l n="1069">ἀμπυκτήρια στομίων</tei:l>
                  <tei:l n="1070">ἄμβασις, οἳ τὰν ἱππίαν</tei:l>
                  <tei:l n="1071">τιμῶσιν Ἀθάναν</tei:l>
                  <tei:l n="1072">καὶ τὸν πόντιον γαιάοχον</tei:l>
                  <tei:l n="1073">Ῥέας φίλον υἱόν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1074"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1074">ἔρδουσʼ ἢ μέλλουσιν; ὡς</tei:l>
                  <tei:l n="1075">προμνᾶταί τί μοι</tei:l>
                  <tei:l n="1076">γνώμα τάχʼ ἀντάσειν</tei:l>
                  <tei:l n="1077">τᾶν δεινὰ τλασᾶν, δεινὰ δʼ εὑρουσᾶν πρὸς αὐθαίμων πάθη.</tei:l>
                  <tei:l n="1078">τελεῖ τελεῖ Ζεύς τι κατʼ ἆμαρ</tei:l>
                  <tei:l n="1079">μάντις εἴμʼ ἐσθλῶν ἀγώνων.</tei:l>
                  <tei:l n="1079a">εἴθʼ ἀελλαία ταχύρρωστος πελειὰς</tei:l>
                  <tei:l n="1080">αἰθερίας νεφέλας κύρσαιμʼ ἄνωθʼ ἀγώνων</tei:l>
                  <tei:l n="1081">αἰωρήσασα τοὐμὸν ὄμμα.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1085"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1085">ἰὼ θεῶν πάνταρχε, παντ-</tei:l>
                  <tei:l n="1086">όπτα Ζεῦ, πόροις</tei:l>
                  <tei:l n="1087">γᾶς τᾶσδε δαμούχοις</tei:l>
                  <tei:l n="1088">σθένει ʼπινικείῳ τὸν εὔαγρον τελειῶσαι λόχον,</tei:l>
                  <tei:l n="1090">σεμνά τε παῖς Παλλὰς Ἀθάνα.</tei:l>
                  <tei:l n="1091">καὶ τὸν ἀγρευτὰν Ἀπόλλω</tei:l>
                  <tei:l n="1092">καὶ κασιγνήταν πυκνοστίκτων ὀπαδὸν</tei:l>
                  <tei:l n="1093">ὠκυπόδων ἐλάφων στέργω διπλᾶς ἀρωγὰς</tei:l>
                  <tei:l n="1094">μολεῖν γᾷ τᾷδε καὶ πολίταις.</tei:l>
                  <tei:l n="1095">ὦ ξεῖνʼ ἀλῆτα, τῷ σκοπῷ μὲν οὐκ ἐρεῖς</tei:l>
                  <tei:l n="1096">ὡς ψευδόμαντις· τὰς κόρας γὰρ εἰσορῶ</tei:l>
                  <tei:l n="1097">τάσδʼ ἆσσον αὖθις ὧδε προσπολουμένας.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
