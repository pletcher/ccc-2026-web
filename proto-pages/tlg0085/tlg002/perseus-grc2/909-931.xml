<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg002.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg002.perseus-grc2:909-931" prev_urn="urn:cts:greekLit:tlg0085.tlg002.perseus-grc2:852-908" next_urn="urn:cts:greekLit:tlg0085.tlg002.perseus-grc2:932-1076">
  <elements><tei:div type="episode">
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Ξέρξης</tei:speaker>
                  <tei:l n="909">ἰώ,</tei:l>
                  <tei:l n="909b">δύστηνος ἐγὼ στυγερᾶς μοίρας</tei:l>
                  <tei:l n="910">τῆσδε κυρήσας ἀτεκμαρτοτάτης,</tei:l>
                  <tei:l n="911">ὡς ὠμοφρόνως δαίμων ἐνέβη</tei:l>
                  <tei:l n="912">Περσῶν γενεᾷ· τί πάθω τλήμων;</tei:l>
                  <tei:l n="913">λέλυται γὰρ ἐμοὶ γυίων ῥώμη</tei:l>
                  <tei:l n="914">τήνδʼ ἡλικίαν ἐσιδόντʼ ἀστῶν.</tei:l>
                  <tei:l n="915">εἴθʼ ὄφελεν, Ζεῦ, κἀμὲ μετʼ ἀνδρῶν</tei:l>
                  <tei:l n="916">τῶν οἰχομένων</tei:l>
                  <tei:l n="917">θανάτου κατὰ μοῖρα καλύψαι.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="918">ὀτοτοῖ, βασιλεῦ, στρατιᾶς ἀγαθῆς</tei:l>
                  <tei:l n="919">καὶ περσονόμου τιμῆς μεγάλης,</tei:l>
                  <tei:l n="920">κόσμου τʼ ἀνδρῶν,</tei:l>
                  <tei:l n="921">οὓς νῦν δαίμων ἐπέκειρεν.</tei:l>
                  <tei:l n="922">γᾶ δʼ αἰάζει τὰν ἐγγαίαν</tei:l>
                  <tei:l n="923">ἥβαν Ξέρξᾳ κταμέναν Ἅιδου</tei:l>
                  <tei:l n="924">σάκτορι Περσᾶν. ᾁδοβάται γὰρ</tei:l>
                  <tei:l n="925">πολλοὶ φῶτες, χώρας ἄνθος,</tei:l>
                  <tei:l n="926">τοξοδάμαντες, πάνυ ταρφύς τις</tei:l>
                  <tei:l n="927">μυριὰς ἀνδρῶν, ἐξέφθινται.</tei:l>
                  <tei:l n="928">αἰαῖ αἰαῖ κεδνᾶς ἀλκᾶς.</tei:l>
                  <tei:l n="929">Ἀσία δὲ χθών, βασιλεῦ γαίας,</tei:l>
                  <tei:l n="930">αἰνῶς αἰνῶς</tei:l>
                  <tei:l n="931">ἐπὶ γόνυ κέκλιται.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
