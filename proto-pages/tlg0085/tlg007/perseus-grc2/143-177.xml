<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2:143-177" prev_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2:1-142" next_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2:179-298">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="143">ἰοὺ ἰοὺ πύπαξ. ἐπάθομεν, φίλαι,—</tei:l>
                  <tei:l n="144">ἦ πολλὰ δὴ παθοῦσα καὶ μάτην ἐγώ,—</tei:l>
                  <tei:l n="145">ἐπάθομεν πάθος δυσαχές, ὦ πόποι,</tei:l>
                  <tei:l n="146">ἄφερτον κακόν·</tei:l>
                  <tei:l n="147">ἐξ ἀρκύων πέπτωκεν οἴχεταί θʼ ὁ θήρ.—</tei:l>
                  <tei:l n="148">ὕπνῳ κρατηθεῖσʼ ἄγραν ὤλεσα.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="149" unit="card"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="149">ἰὼ παῖ Διός, ἐπίκλοπος πέλῃ,—</tei:l>
                  <tei:l n="150">νέος δὲ γραίας δαίμονας καθιππάσω,—</tei:l>
                  <tei:l n="151">τὸν ἱκέταν σέβων, ἄθεον ἄνδρα καὶ</tei:l>
                  <tei:l n="152">τοκεῦσιν πικρόν·</tei:l>
                  <tei:l n="153">τὸν μητραλοίαν δʼ ἐξέκλεψας ὢν θεός.—</tei:l>
                  <tei:l n="154">τί τῶνδʼ ἐρεῖ τις δικαίως ἔχειν;</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="155" unit="card"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="155">ἐμοὶ δʼ ὄνειδος ἐξ ὀνειράτων μολὸν</tei:l>
                  <tei:l n="156">ἔτυψεν δίκαν διφρηλάτου</tei:l>
                  <tei:l n="157">μεσολαβεῖ κέντρῳ</tei:l>
                  <tei:l n="158">ὑπὸ φρένας, ὑπὸ λοβόν.—</tei:l>
                  <tei:l n="160">πάρεστι μαστίκτορος δαΐου δαμίου</tei:l>
                  <tei:l n="161">βαρὺ τὸ περίβαρυ κρύος ἔχειν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="162" unit="card"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="162">τοιαῦτα δρῶσιν οἱ νεώτεροι θεοί,</tei:l>
                  <tei:l n="163">κρατοῦντες τὸ πᾶν δίκας πλέον</tei:l>
                  <tei:l n="164">φονολιβῆ θρόνον</tei:l>
                  <tei:l n="165">περὶ πόδα, περὶ κάρα.—</tei:l>
                  <tei:l n="166">πάρεστι γᾶς ὀμφαλὸν προσδρακεῖν αἱμάτων</tei:l>
                  <tei:l n="167">βλοσυρὸν ἀρόμενον ἄγος ἔχειν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="169" unit="card"/>
            <tei:div n="3" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="169">ἐφεστίῳ δὲ μάντις ὢν μιάσματι</tei:l>
                  <tei:l n="170">μυχὸν ἐχράνατʼ αὐτόσσυτος, αὐτόκλητος,</tei:l>
                  <tei:l n="171">παρὰ νόμον θεῶν βρότεα μὲν τίων,</tei:l>
                  <tei:l n="172">παλαιγενεῖς δὲ μοίρας φθίσας.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="174" unit="card"/>
            <tei:div n="3" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="174">κἀμοί γε λυπρός, καὶ τὸν οὐκ ἐκλύσεται,</tei:l>
                  <tei:l n="175">ὑπό τε γᾶν φυγὼν οὔ ποτʼ ἐλευθεροῦται.</tei:l>
                  <tei:l n="176">ποτιτρόπαιος ὢν δʼ ἕτερον ἐν κάρᾳ</tei:l>
                  <tei:l n="177">μιάστορʼ ἐκ γένους πάσεται.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
