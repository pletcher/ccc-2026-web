<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2:1032-1047" prev_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2:1021-1031">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Προπομποί</tei:speaker>
                  <tei:l n="1032">βᾶτε δόμῳ, μεγάλαι φιλότιμοι</tei:l>
                  <tei:l n="1033">Νυκτὸς παῖδες ἄπαιδες, ὑπʼ εὔφρονι πομπᾷ,</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="1035" unit="card"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Προπομποί</tei:speaker>
                  <tei:l n="1035">εὐφαμεῖτε δέ, χωρῖται,</tei:l>
                  <tei:l n="1036">γᾶς ὑπὸ κεύθεσιν ὠγυγίοισιν,</tei:l>
                  <tei:l n="1037">
                     <tei:del>καὶ</tei:del> τιμαῖς καὶ θυσίαις περίσεπτα τυχοῦσαι,</tei:l>
                  <tei:l n="1038">εὐφαμεῖτε δὲ πανδαμεί.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="1040" unit="card"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Προπομποί</tei:speaker>
                  <tei:l n="1040">ἵλαοι δὲ καὶ σύμφρονες γᾷ</tei:l>
                  <tei:l n="1041">δεῦρʼ ἴτε, σεμναί, <tei:add>ξὺν</tei:add> πυριδάπτῳ</tei:l>
                  <tei:l n="1042">λαμπάδι τερπόμεναι καθʼ ὁδόν.</tei:l>
                  <tei:l n="1043">ὀλολύξατε νῦν ἐπὶ μολπαῖς.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="1044" unit="card"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Προπομποί</tei:speaker>
                  <tei:l n="1044">σπονδαὶ δʼ ἐς τὸ πᾶν ἐκ μετοίκων</tei:l>
                  <tei:l n="1045">Παλλάδος ἀστοῖς. Ζεὺς <tei:add>ὁ</tei:add> πανόπτας</tei:l>
                  <tei:l n="1046">οὕτω Μοῖρά τε συγκατέβα.</tei:l>
                  <tei:l n="1047">ὀλολύξατε νῦν ἐπὶ μολπαῖς.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
      </elements>
</citationChunk>
