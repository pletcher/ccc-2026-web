<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2:1021-1031" prev_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2:916-1020" next_urn="urn:cts:greekLit:tlg0085.tlg007.perseus-grc2:1032-1047">
  <elements><tei:div type="episode">
            <tei:sp>
               <tei:speaker>Ἀθηνᾶ</tei:speaker>
               <tei:l n="1021">αἰνῶ τε μύθους τῶνδε τῶν κατευγμάτων</tei:l>
               <tei:l n="1022">πέμψω τε φέγγει λαμπάδων σελασφόρων</tei:l>
               <tei:l n="1023">εἰς τοὺς ἔνερθε καὶ κατὰ χθονὸς τόπους</tei:l>
               <tei:l n="1024">ξὺν προσπόλοισιν, αἵτε φρουροῦσιν βρέτας</tei:l>
               <tei:l n="1025">τοὐμὸν δικαίως. ὄμμα γὰρ πάσης χθονὸς</tei:l>
               <tei:l n="1026">Θησῇδος ἐξίκοιτʼ ἂν εὐκλεὴς λόχος</tei:l>
               <tei:l n="1027">παίδων, γυναικῶν, καὶ στόλος πρεσβυτίδων.</tei:l>
               <tei:l n="1028">
                  <tei:milestone ed="P" unit="para"/>φοινικοβάπτοις ἐνδυτοῖς ἐσθήμασι</tei:l>
               <tei:l n="1029">τιμᾶτε, καὶ τὸ φέγγος ὁρμάσθω πυρός,</tei:l>
               <tei:l n="1030">ὅπως ἂν εὔφρων ἥδʼ ὁμιλία χθονὸς</tei:l>
               <tei:l n="1031">τὸ λοιπὸν εὐάνδροισι συμφοραῖς πρέπῃ.</tei:l>
            </tei:sp>
         </tei:div>
         </elements>
</citationChunk>
