<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg004.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg004.perseus-grc2:966-1010" prev_urn="urn:cts:greekLit:tlg0085.tlg004.perseus-grc2:957-965" next_urn="urn:cts:greekLit:tlg0085.tlg004.perseus-grc2:1011-1084">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="966">ἠέ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="966b">ἠέ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="967">μαίνεται γόοισι φρήν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="968">ἐντὸς δὲ καρδία στένει.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="969">ἰὼ ἰὼ πάνδυρτε σύ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="970">σὺ δʼ αὖτε καὶ πανάθλιε.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="971">πρὸς φίλου <tei:del>γʼ·</tei:del> ἔφθισο.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="972">καὶ φίλον ἔκτανες.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="973">διπλᾶ λέγειν—</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="974">διπλᾶ δʼ ὁρᾶν—</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="975">ἄχθεα τῶνδε τάδʼ ἐγγύθεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="976">πέλας ἀδελφέʼ ἀδελφεῶν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="977">ἰὼ Μοῖρα βαρυδότειρα μογερά,</tei:l>
                  <tei:l n="978">πότνιά τʼ Οἰδίπου σκιά,</tei:l>
                  <tei:l n="979">μέλαινʼ Ἐρινύς, ἦ μεγασθενής τις εἶ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="980" unit="card"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="980">ἠέ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="980b">ἠέ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="981">δυσθέατα πήματα —</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="982">ἔδειξεν ἐκ φυγᾶς ἐμοί.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="983">οὐδʼ ἵκεθʼ ὡς κατέκτανεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="984">σωθεὶς δὲ πνεῦμʼ ἀπώλεσεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="985">ὤλεσε δῆτʼ <tei:add>ἄγαν</tei:add>.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="986">καὶ τὸν ἐνόσφισεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="987">τάλαν γένος.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="988">τάλαν πάθος.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="989">δύστονα κήδεʼ ὁμαίμονα.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="990">
                     <tei:sic>δίυγρα</tei:sic> τριπάλτων πημάτων.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="991">ἰὼ Μοῖρα βαρυδότειρα μογερά,</tei:l>
                  <tei:l n="992">πότνιά τʼ Οἰδίπου σκιά,</tei:l>
                  <tei:l n="993">μέλαινʼ Ἐρινύς, ἦ μεγασθενής τις εἶ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone n="994" unit="card"/>
            <tei:div type="epode">
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="994">σὺ τοί νιν οἶσθα διαπερῶν—</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="995">σὺ δʼ οὐδὲν ὕστερος μαθών—</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="996">ἐπεὶ κατῆλθες ἐς πόλιν,</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="997">δορός γε τῷδʼ ἀντηρέτας.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="998">ὀλοὰ λέγειν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="999">ὀλοὰ δʼ ὁρᾶν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1000">ἰὼ πόνος—</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1001">ἰὼ κακά—</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1002">δώμασι καὶ χθονί.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1003">πρὸ πάντων δʼ ἐμοί.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1004">καὶ τὸ πρόσω γʼ ἐμοί.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1005">ἰὼ ἰὼ δυστόνων κακῶν, ἄναξ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1006">ἰὼ πάντων πολυστονώτατοι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1007">ἰὼ ἰὼ δαιμονῶντες ἄτᾳ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1008">ἰὼ ἰώ, ποῦ σφε θήσομεν χθονός;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1009">ἰώ, ὅπου <tei:add>ʼσʼτι</tei:add> τιμιώτατον.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1010">ἰὼ ἰώ, πῆμα πατρὶ πάρευνον.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
