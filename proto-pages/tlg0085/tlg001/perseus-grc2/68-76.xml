  <elements><tei:div n="3" type="strophe">
            <tei:sp>
               <tei:speaker>Χορός</tei:speaker>
               <tei:l n="68">τὼς καὶ ἐγὼ φιλόδυρ-</tei:l>
               <tei:l n="69">τος Ἰαονίοισι νόμοισι</tei:l>
               <tei:l n="70">δάπτω τὰν ἁπαλὰν</tei:l>
               <tei:l n="71">Νειλοθερῆ παρειὰν</tei:l>
               <tei:l n="72">ἀπειρόδακρύν τε καρδίαν.</tei:l>
               <tei:l n="73">γοεδνὰ δʼ ἀνθεμίζομαι</tei:l>
               <tei:l n="74">δειμαίνουσα φίλους, τᾶσδε φυγᾶς</tei:l>
               <tei:l n="75">ἀερίας ἀπὸ γᾶς</tei:l>
               <tei:l n="76">εἴ τις ἐστὶ κηδεμών.</tei:l>
            </tei:sp>
