<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg005.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg005.perseus-grc2:975-1033" prev_urn="urn:cts:greekLit:tlg0085.tlg005.perseus-grc2:782-974" next_urn="urn:cts:greekLit:tlg0085.tlg005.perseus-grc2:1035-1071">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="975">τίπτε μοι τόδʼ ἐμπέδως</tei:l>
                  <tei:l n="976">δεῖμα προστατήριον</tei:l>
                  <tei:l n="977">καρδίας τερασκόπου ποτᾶται,</tei:l>
                  <tei:l n="978">μαντιπολεῖ δʼ ἀκέλευστος ἄμισθος ἀοιδά,</tei:l>
                  <tei:l n="980">οὐδʼ ἀποπτύσαι δίκαν</tei:l>
                  <tei:l n="981">δυσκρίτων ὀνειράτων</tei:l>
                  <tei:l n="982">θάρσος εὐπειθὲς ἵ-</tei:l>
                  <tei:l n="983">ζει φρενὸς φίλον θρόνον;</tei:l>
                  <tei:l n="984">χρόνος δʼ ἐπὶ πρυμνησίων ξυνεμβολαῖς</tei:l>
                  <tei:l n="985">ψαμμίʼ ἀκτᾶς παρή-</tei:l>
                  <tei:l n="986">μησεν, εὖθʼ ὑπʼ Ἴλιον</tei:l>
                  <tei:l n="987">ὦρτο ναυβάτας στρατός.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:div n="1" type="antistrophe">
               <tei:milestone ed="p" n="988" unit="card"/>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="988">πεύθομαι δʼ ἀπʼ ὀμμάτων</tei:l>
                  <tei:l n="989">νόστον, αὐτόμαρτυς ὤν·</tei:l>
                  <tei:l n="990">τὸν δʼ ἄνευ λύρας ὅμως ὑμνῳδεῖ</tei:l>
                  <tei:l n="991">θρῆνον Ἐρινύος αὐτοδίδακτος ἔσωθεν</tei:l>
                  <tei:l n="992">θυμός, οὐ τὸ πᾶν ἔχων</tei:l>
                  <tei:l n="993">ἐλπίδος φίλον θράσος.</tei:l>
                  <tei:l n="995">σπλάγχνα δʼ οὔτοι ματᾴ-</tei:l>
                  <tei:l n="996">ζει πρὸς ἐνδίκοις φρεσὶν</tei:l>
                  <tei:l n="997">τελεσφόροις δίναις κυκώμενον κέαρ.</tei:l>
                  <tei:l n="998">εὔχομαι δʼ ἐξ ἐμᾶς</tei:l>
                  <tei:l n="999">ἐλπίδος ψύθη πεσεῖν</tei:l>
                  <tei:l n="1000">ἐς τὸ μὴ τελεσφόρον.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:div n="2" type="strophe">
               <tei:milestone ed="p" n="1001" unit="card"/>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1001">μάλα γέ τοι τὸ μεγάλας ὑγιείας</tei:l>
                  <tei:l n="1002">ἀκόρεστον τέρμα· νόσος γάρ</tei:l>
                  <tei:l n="1003">γείτων ὁμότοιχος ἐρείδει.</tei:l>
                  <tei:l n="1005">καὶ πότμος εὐθυπορῶν</tei:l>
                  <tei:l n="1006">
                     <tei:gap reason="lost"/>
                  </tei:l>
                  <tei:l n="1007">ἀνδρὸς ἔπαισεν ἄφαντον ἕρμα.</tei:l>
                  <tei:l n="1008">καὶ πρὸ μέν τι χρημάτων</tei:l>
                  <tei:l n="1009">κτησίων ὄκνος βαλὼν</tei:l>
                  <tei:l n="1010">σφενδόνας ἀπʼ εὐμέτρου,</tei:l>
                  <tei:l n="1011">οὐκ ἔδυ πρόπας δόμος</tei:l>
                  <tei:l n="1012">πημονᾶς γέμων ἄγαν,</tei:l>
                  <tei:l n="1013">οὐδʼ ἐπόντισε σκάφος.</tei:l>
                  <tei:l n="1014">πολλά τοι δόσις ἐκ Διὸς ἀμφιλα-</tei:l>
                  <tei:l n="1015">φής τε καὶ ἐξ ἀλόκων ἐπετειᾶν</tei:l>
                  <tei:l n="1016">νῆστιν ὤλεσεν νόσον.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:div n="2" type="antistrophe">
               <tei:milestone ed="p" n="1017" unit="card"/>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1017">τὸ δʼ ἐπὶ γᾶν πεσὸν ἅπαξ θανάσιμον</tei:l>
                  <tei:l n="1020">πρόπαρ ἀνδρὸς μέλαν αἷμα τίς ἂν</tei:l>
                  <tei:l n="1021">πάλιν ἀγκαλέσαιτʼ ἐπαείδων;</tei:l>
                  <tei:l n="1022">οὐδὲ τὸν ὀρθοδαῆ</tei:l>
                  <tei:l n="1023">τῶν φθιμένων ἀνάγειν</tei:l>
                  <tei:l n="1024">Ζεὺς ἀπέπαυσεν ἐπʼ εὐλαβείᾳ;</tei:l>
                  <tei:l n="1025">εἰ δὲ μὴ τεταγμένα</tei:l>
                  <tei:l n="1026">μοῖρα μοῖραν ἐκ θεῶν</tei:l>
                  <tei:l n="1027">εἶργε μὴ πλέον φέρειν,</tei:l>
                  <tei:l n="1028">προφθάσασα καρδία</tei:l>
                  <tei:l n="1029">γλῶσσαν ἂν τάδʼ ἐξέχει.</tei:l>
                  <tei:l n="1030">νῦν δʼ ὑπὸ σκότῳ βρέμει</tei:l>
                  <tei:l n="1031">θυμαλγής τε καὶ οὐδὲν ἐπελπομέν-</tei:l>
                  <tei:l n="1032">α ποτὲ καίριον ἐκτολυπεύσειν</tei:l>
                  <tei:l n="1033">ζωπυρουμένας φρενός.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
