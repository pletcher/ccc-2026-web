<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0085.tlg005.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0085.tlg005.perseus-grc2:1448-1576" prev_urn="urn:cts:greekLit:tlg0085.tlg005.perseus-grc2:1431-1447" next_urn="urn:cts:greekLit:tlg0085.tlg005.perseus-grc2:1577-1673">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1448">φεῦ, τίς ἂν ἐν τάχει, μὴ περιώδυνος,</tei:l>
                  <tei:l n="1449">μηδὲ δεμνιοτήρης,</tei:l>
                  <tei:l n="1450">μόλοι τὸν αἰεὶ φέρουσʼ ἐν ἡμῖν</tei:l>
                  <tei:l n="1451">Μοῖρʼ ἀτέλευτον ὕπνον, δαμέντος</tei:l>
                  <tei:l n="1452">φύλακος εὐμενεστάτου <tei:del>καὶ</tei:del>
                  </tei:l>
                  <tei:l n="1453">πολλὰ τλάντος γυναικὸς διαί·</tei:l>
                  <tei:l n="1454">πρὸς γυναικὸς δʼ ἀπέφθισεν βίον.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1455" unit="card"/>
            <tei:div n="1" type="ephymn.">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1455">ἰὼ <tei:add>ἰὼ</tei:add> παράνους Ἑλένα</tei:l>
                  <tei:l n="1456">μία τὰς πολλάς, τάς πάνυ πολλὰς</tei:l>
                  <tei:l n="1457">ψυχὰς ὀλέσασʼ ὑπὸ Τροίᾳ.</tei:l>
                  <tei:l n="1458">νῦν <tei:del>δὲ</tei:del> τελέαν πολύμναστον ἐπηνθίσω</tei:l>
                  <tei:l n="1460">διʼ αἷμʼ ἄνιπτον. ἦ τις ἦν τότʼ ἐν δόμοις</tei:l>
                  <tei:l n="1461">ἔρις ἐρίδματος ἀνδρὸς οἰζύς.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1462" unit="card"/>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Κλυταιμήστρα</tei:speaker>
                  <tei:l n="1462">μηδὲν θανάτου μοῖραν ἐπεύχου</tei:l>
                  <tei:l n="1463">τοῖσδε βαρυνθείς·</tei:l>
                  <tei:l n="1464">μηδʼ εἰς Ἑλένην κότον ἐκτρέψῃς,</tei:l>
                  <tei:l n="1465">ὡς ἀνδρολέτειρʼ, ὡς μία πολλῶν</tei:l>
                  <tei:l n="1466">ἀνδρῶν ψυχὰς Δαναῶν ὀλέσασʼ</tei:l>
                  <tei:l n="1467">ἀξύστατον ἄλγος ἔπραξεν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1468" unit="card"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1468">δαῖμον, ὃς ἐμπίτνεις δώμασι καὶ διφυί-</tei:l>
                  <tei:l n="1469">οισι Τανταλίδαισιν,</tei:l>
                  <tei:l n="1470">κράτος <tei:add>τʼ</tei:add> ἰσόψυχον ἐκ γυναικῶν</tei:l>
                  <tei:l n="1471">καρδιόδηκτον ἐμοὶ κρατύνεις.</tei:l>
                  <tei:l n="1472">ἐπὶ δὲ σώματος δίκαν <tei:del>μοι</tei:del>
                  </tei:l>
                  <tei:l n="1473">κόρακος ἐχθροῦ σταθεῖσʼ ἐκνόμως</tei:l>
                  <tei:l n="1474">ὕμνον ὑμνεῖν ἐπεύχεται <tei:add>˘¯</tei:add>
                  </tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1475" unit="card"/>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Κλυταιμήστρα</tei:speaker>
                  <tei:l n="1475">νῦν δʼ ὤρθωσας στόματος γνώμην,</tei:l>
                  <tei:l n="1476">τὸν τριπάχυντον</tei:l>
                  <tei:l n="1477">δαίμονα γέννης τῆσδε κικλήσκων.</tei:l>
                  <tei:l n="1478">ἐκ τοῦ γὰρ ἔρως αἱματολοιχὸς</tei:l>
                  <tei:l n="1479">νείρᾳ τρέφεται, πρὶν καταλῆξαι</tei:l>
                  <tei:l n="1480">τὸ παλαιὸν ἄχος, νέος ἰχώρ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1481" unit="card"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1481">ἦ μέγαν οἰκονόμον</tei:l>
                  <tei:l n="1482">δαίμονα καὶ βαρύμηνιν αἰνεῖς,</tei:l>
                  <tei:l n="1483">φεῦ φεῦ, κακὸν αἶνον ἀτη-</tei:l>
                  <tei:l n="1484">ρᾶς τύχας ἀκορέστου·</tei:l>
                  <tei:l n="1485">ἰὴ ἰή, διαὶ Διὸς</tei:l>
                  <tei:l n="1486">παναιτίου πανεργέτα·</tei:l>
                  <tei:l n="1487">τί γὰρ βροτοῖς ἄνευ Διὸς τελεῖται;</tei:l>
                  <tei:l n="1488">τί τῶνδʼ οὐ θεόκραντόν ἐστιν;</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1489" unit="card"/>
            <tei:div n="2" type="ephymn.">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1489">ἰὼ ἰὼ βασιλεῦ βασιλεῦ,</tei:l>
                  <tei:l n="1490">πῶς σε δακρύσω;</tei:l>
                  <tei:l n="1491">φρενὸς ἐκ φιλίας τί ποτʼ εἴπω;</tei:l>
                  <tei:l n="1492">κεῖσαι δʼ ἀράχνης ἐν ὑφάσματι τῷδʼ</tei:l>
                  <tei:l n="1493">ἀσεβεῖ θανάτῳ βίον ἐκπνέων.</tei:l>
                  <tei:l n="1494">ὤμοι μοι κοίταν τάνδʼ ἀνελεύθερον</tei:l>
                  <tei:l n="1495">δολίῳ μόρῳ δαμεὶς <tei:add>δάμαρτος</tei:add>
                  </tei:l>
                  <tei:l n="1496">ἐκ χερὸς ἀμφιτόμῳ βελέμνῳ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1497" unit="card"/>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Κλυταιμήστρα</tei:speaker>
                  <tei:l n="1497">αὐχεῖς εἶναι τόδε τοὔργον ἐμόν;</tei:l>
                  <tei:l n="1498">μηδʼ ἐπιλεχθῇς</tei:l>
                  <tei:l n="1499">Ἀγαμεμνονίαν εἶναί μʼ ἄλοχον.</tei:l>
                  <tei:l n="1500">φανταζόμενος δὲ γυναικὶ νεκροῦ</tei:l>
                  <tei:l n="1501">τοῦδʼ ὁ παλαιὸς δριμὺς ἀλάστωρ</tei:l>
                  <tei:l n="1502">Ἀτρέως χαλεποῦ θοινατῆρος</tei:l>
                  <tei:l n="1503">τόνδʼ ἀπέτεισεν,</tei:l>
                  <tei:l n="1504">τέλεον νεαροῖς ἐπιθύσας.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1505" unit="card"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1505">ὡς μὲν ἀναίτιος εἶ</tei:l>
                  <tei:l n="1506">τοῦδε φόνου τίς ὁ μαρτυρήσων;</tei:l>
                  <tei:l n="1507">πῶς πῶς; πατρόθεν δὲ συλλή-</tei:l>
                  <tei:l n="1508">πτωρ γένοιτʼ ἂν ἀλάστωρ.</tei:l>
                  <tei:l n="1509">βιάζεται δʼ ὁμοσπόροις</tei:l>
                  <tei:l n="1510">ἐπιρροαῖσιν αἱμάτων</tei:l>
                  <tei:l n="1511">μέλας Ἄρης, ὅποι δίκαν προβαίνων</tei:l>
                  <tei:l n="1512">πάχνᾳ κουροβόρῳ παρέξει.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1513" unit="card"/>
            <tei:div n="2" type="ephymn">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1513">ἰὼ ἰὼ βασιλεῦ βασιλεῦ,</tei:l>
                  <tei:l n="1514">πῶς σε δακρύσω;</tei:l>
                  <tei:l n="1515">φρενὸς ἐκ φιλίας τί ποτʼ εἴπω;</tei:l>
                  <tei:l n="1516">κεῖσαι δʼ ἀράχνης ἐν ὑφάσματι τῷδʼ</tei:l>
                  <tei:l n="1517">ἀσεβεῖ θανάτῳ βίον ἐκπνέων.</tei:l>
                  <tei:l n="1518">ὤμοι μοι κοίταν τάνδʼ ἀνελεύθερον</tei:l>
                  <tei:l n="1519">δολίῳ μόρῳ δαμεὶς</tei:l>
                  <tei:l n="1520">ἐκ χερὸς ἀμφιτόμῳ βελέμνῳ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1521" unit="card"/>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Κλυταιμήστρα</tei:speaker>
                  <tei:l n="1521">
                     <tei:del> οὔτʼ ἀνελεύθερον οἶμαι θάνατον</tei:del>
                  </tei:l>
                  <tei:l n="1522">
                     <tei:del>τῷδε γενέσθαι.</tei:del>
                  </tei:l>
                  <tei:l n="1523">οὐδὲ γὰρ οὗτος δολίαν ἄτην</tei:l>
                  <tei:l n="1524">οἴκοισιν ἔθηκʼ;</tei:l>
                  <tei:l n="1525">ἀλλʼ ἐμὸν ἐκ τοῦδʼ ἔρνος ἀερθέν.</tei:l>
                  <tei:l n="1526">τὴν πολυκλαύτην Ἰφιγενείαν,</tei:l>
                  <tei:l n="1527">ἄξια δράσας ἄξια πάσχων</tei:l>
                  <tei:l n="1528">μηδὲν ἐν Ἅιδου μεγαλαυχείτω,</tei:l>
                  <tei:l n="1529">ξιφοδηλήτῳ,</tei:l>
                  <tei:l n="1529b">θανάτῳ τείσας ἅπερ ἦρξεν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1530" unit="card"/>
            <tei:div n="3" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1530">ἀμηχανῶ φροντίδος στερηθεὶς</tei:l>
                  <tei:l n="1531">εὐπάλαμον μέριμναν</tei:l>
                  <tei:l n="1532">ὅπα τράπωμαι, πίτνοντος οἴκου.</tei:l>
                  <tei:l n="1533">δέδοικα δʼ ὄμβρου κτύπον δομοσφαλῆ</tei:l>
                  <tei:l n="1534">τὸν αἱματηρόν· ψακὰς δὲ λήγει.</tei:l>
                  <tei:l n="1535">δίκην δʼ ἐπʼ ἄλλο πρᾶγμα θηγάνει βλάβης</tei:l>
                  <tei:l n="1536">πρὸς ἄλλαις θηγάναισι μοῖρα.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1537" unit="card"/>
            <tei:div n="3" type="ephymn">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1537">ἰὼ γᾶ γᾶ, εἴθʼ ἔμʼ ἐδέξω,</tei:l>
                  <tei:l n="1538">πρὶν τόνδʼ ἐπιδεῖν ἀργυροτοίχου</tei:l>
                  <tei:l n="1540">δροίτης κατέχοντα χάμευναν.</tei:l>
                  <tei:l n="1541">τίς ὁ θάψων νιν; τίς ὁ θρηνήσων;</tei:l>
                  <tei:l n="1542">ἦ σὺ τόδʼ ἔρξαι τλήσῃ, κτείνασʼ</tei:l>
                  <tei:l n="1543">ἄνδρα τὸν αὑτῆς ἀποκωκῦσαι</tei:l>
                  <tei:l n="1545">ψυχῇ τʼ ἄχαριν χάριν ἀντʼ ἔργων</tei:l>
                  <tei:l n="1546">μεγάλων ἀδίκως ἐπικρᾶναι;</tei:l>
                  <tei:l n="1547">τίς δʼ ἐπιτύμβιον αἶνον ἐπʼ ἀνδρὶ θείῳ</tei:l>
                  <tei:l n="1548">σὺν δακρύοις ἰάπτων</tei:l>
                  <tei:l n="1550">ἀληθείᾳ φρενῶν πονήσει;</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1551" unit="card"/>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Κλυταιμήστρα</tei:speaker>
                  <tei:l n="1551">οὐ σὲ προσήκει τὸ μέλημʼ ἀλέγειν</tei:l>
                  <tei:l n="1552">τοῦτο· πρὸς ἡμῶν</tei:l>
                  <tei:l n="1553">κάππεσε, κάτθανε, καὶ καταθάψομεν,</tei:l>
                  <tei:l n="1554">οὐχ ὑπὸ κλαυθμῶν τῶν ἐξ οἴκων,</tei:l>
                  <tei:l n="1555">ἀλλʼ Ἰφιγένειά νιν ἀσπασίως</tei:l>
                  <tei:l n="1556">θυγάτηρ, ὡς χρή,</tei:l>
                  <tei:l n="1557">πατέρʼ ἀντιάσασα πρὸς ὠκύπορον</tei:l>
                  <tei:l n="1558">πόρθμευμʼ ἀχέων</tei:l>
                  <tei:l n="1559">περὶ χεῖρε βαλοῦσα φιλήσει.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1560" unit="card"/>
            <tei:div n="3" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1560">ὄνειδος ἥκει τόδʼ ἀντʼ ὀνείδους.</tei:l>
                  <tei:l n="1561">δύσμαχα δʼ ἔστι κρῖναι.</tei:l>
                  <tei:l n="1562">φέρει φέροντʼ, ἐκτίνει δʼ ὁ καίνων.</tei:l>
                  <tei:l n="1563">μίμνει δὲ μίμνοντος ἐν θρόνῳ Διὸς</tei:l>
                  <tei:l n="1564">παθεῖν τὸν ἔρξαντα· θέσμιον γάρ.</tei:l>
                  <tei:l n="1565">τίς ἂν γονὰν ἀραῖον ἐκβάλοι δόμων;</tei:l>
                  <tei:l n="1566">κεκόλληται γένος πρὸς ἄτᾳ.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone ed="p" n="1567" unit="card"/>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Κλυταιμήστρα</tei:speaker>
                  <tei:l n="1567">ἐς τόνδʼ ἐνέβης ξὺν ἀληθείᾳ</tei:l>
                  <tei:l n="1568">χρησμόν. ἐγὼ δʼ οὖν</tei:l>
                  <tei:l n="1569">ἐθέλω δαίμονι τῷ Πλεισθενιδῶν</tei:l>
                  <tei:l n="1570">ὅρκους θεμένη τάδε μὲν στέργειν,</tei:l>
                  <tei:l n="1571">δύστλητά περ ὄνθʼ· ὃ δὲ λοιπόν, ἰόντʼ</tei:l>
                  <tei:l n="1572">ἐκ τῶνδε δόμων ἄλλην γενεὰν</tei:l>
                  <tei:l n="1573">τρίβειν θανάτοις αὐθένταισι.</tei:l>
                  <tei:l n="1574">κτεάνων τε μέρος</tei:l>
                  <tei:l n="1575a">βαιὸν ἐχούσῃ πᾶν ἀπόχρη μοι</tei:l>
                  <tei:l n="1575b">μανίας μελάθρων</tei:l>
                  <tei:l n="1576">ἀλληλοφόνους ἀφελούσῃ.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
