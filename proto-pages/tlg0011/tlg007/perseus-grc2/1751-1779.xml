<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1751-1779" prev_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1670-1750">
  <elements><tei:div type="episode">
            <tei:sp>
               <tei:speaker>Θησεύς</tei:speaker>
               <tei:l n="1751">παύετε θρήνων, παῖδες· ἐν οἷς γὰρ</tei:l>
               <tei:l n="1752">χάρις ἡ χθονία ξύνʼ ἀπόκειται,</tei:l>
               <tei:l n="1753">πενθεῖν οὐ χρή· νέμεσις γάρ.</tei:l>
            </tei:sp>
            <tei:sp>
               <tei:speaker>Ἀντιγόνη</tei:speaker>
               <tei:l n="1754">ὦ τέκνον Αἰγέως, προσπίτνομέν σοι.</tei:l>
            </tei:sp>
            <tei:sp>
               <tei:speaker>Θησεύς</tei:speaker>
               <tei:l n="1755">τίνος, ὦ παῖδες, χρείας ἀνύσαι;</tei:l>
            </tei:sp>
            <tei:sp>
               <tei:speaker>Ἀντιγόνη</tei:speaker>
               <tei:l n="1756">τύμβον θέλομεν προσιδεῖν αὐταὶ πατρὸς ἡμετέρου.</tei:l>
            </tei:sp>
            <tei:sp>
               <tei:speaker>Θησεύς</tei:speaker>
               <tei:l n="1757">ἀλλʼ οὐ θεμιτόν.</tei:l>
            </tei:sp>
            <tei:sp>
               <tei:speaker>Ἀντιγόνη</tei:speaker>
               <tei:l n="1758">πῶς εἶπας, ἄναξ, κοίρανʼ Ἀθηνῶν;</tei:l>
            </tei:sp>
            <tei:div type="anapests">
               <tei:sp>
                  <tei:speaker>Θησεύς</tei:speaker>
                  <tei:l n="1760">ὦ παῖδες, ἀπεῖπεν ἐμοὶ κεῖνος</tei:l>
                  <tei:l n="1761">μήτε πελάζειν ἐς τούσδε τόπους</tei:l>
                  <tei:l n="1762">μήτʼ ἐπιφωνεῖν μηδένα θνητῶν</tei:l>
                  <tei:l n="1763">θήκην ἱεράν, ἣν κεῖνος ἔχει.</tei:l>
                  <tei:l n="1764">καὶ ταῦτά μʼ ἔφη πράσσοντα καλῶς</tei:l>
                  <tei:l n="1765">χώραν ἕξειν αἰὲν ἄλυπον.</tei:l>
                  <tei:l n="1766">ταῦτʼ οὖν ἔκλυεν δαίμων ἡμῶν</tei:l>
                  <tei:l n="1767">χὠ πάντʼ ἀΐων Διὸς Ὅρκος.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1768">ἀλλʼ εἰ τάδʼ ἔχει κατὰ νοῦν κείνῳ,</tei:l>
                  <tei:l n="1769">ταῦτʼ ἂν ἀπαρκοῖ· Θήβας δʼ ἡμᾶς</tei:l>
                  <tei:l n="1770">τὰς ὠγυγίους πέμψον, ἐάν πως</tei:l>
                  <tei:l n="1771">διακωλύσωμεν ἰόντα φόνον</tei:l>
                  <tei:l n="1772">τοῖσιν ὁμαίμοις.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Θησεύς</tei:speaker>
                  <tei:l n="1773">δράσω καὶ τάδε καὶ πάνθʼ ὁπόσʼ ἂν</tei:l>
                  <tei:l n="1774">μέλλω πράσσειν πρόσφορά θʼ ὑμῖν</tei:l>
                  <tei:l n="1775">καὶ τῷ κατὰ γῆς, ὃς νέον ἔρρει,</tei:l>
                  <tei:l n="1776">πρὸς χάριν· οὐ δεῖ μʼ ἀποκάμνειν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1777">ἀλλʼ ἀποπαύετε μηδʼ ἐπὶ πλείω</tei:l>
                  <tei:l n="1778">θρῆνον ἐγείρετε·</tei:l>
                  <tei:l n="1779">πάντως γὰρ ἔχει τάδε κῦρος.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
      </elements>
</citationChunk>
