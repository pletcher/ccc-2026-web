<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1670-1750" prev_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1579-1669" next_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1751-1779">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1670">αἰαῖ, φεῦ, ἔστιν ἔστι νῷν δὴ </tei:l>
                  <tei:l n="1671">οὐ τὸ μέν, ἄλλο δὲ μή, πατρὸς ἔμφυτον</tei:l>
                  <tei:l n="1672">ἄλαστον αἷμα δυσμόροιν στενάζειν,</tei:l>
                  <tei:l n="1673">ᾧτινι τὸν πολὺν</tei:l>
                  <tei:l n="1674">ἄλλοτε μὲν πόνον ἔμπεδον εἴχομεν,</tei:l>
                  <tei:l n="1675">ἐν πυμάτῳ δʼ ἀλόγιστα παροίσομεν</tei:l>
                  <tei:l n="1676">ἰδόντε καὶ παθόντε.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1677" part="I">τί δʼ ἔστιν;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1677a" part="F">ἔστιν μὲν εἰκάσαι, φίλοι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1678" part="I">βέβηκεν;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1678a" part="F">ὡς μάλιστʼ ἂν ἐν πόθῳ λάβοις.</tei:l>
                  <tei:l n="1679">τί γάρ, ὅτῳ μήτʼ Ἄρης</tei:l>
                  <tei:l n="1680">μήτε πόντος ἀντέκυρσεν,</tei:l>
                  <tei:l n="1681">ἄσκοποι δὲ πλάκες ἔμαρψαν</tei:l>
                  <tei:l n="1682">ἐν ἀφανεῖ τινι μόρῳ φερόμενον.</tei:l>
                  <tei:l n="1683">τάλαινα· νῶν δʼ ὀλεθρία</tei:l>
                  <tei:l n="1684">νὺξ ἐπʼ ὄμμασιν βέβακε.</tei:l>
                  <tei:l n="1685">πῶς γὰρ ἤ τινʼ ἀπίαν</tei:l>
                  <tei:l n="1686">γᾶν ἢ πόντιον κλύδωνʼ ἀλώμεναι, βίου δύσοιστον ἕξομεν τροφάν;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1687">οὐ κάτοιδα. κατά με φόνιος</tei:l>
                  <tei:l n="1688">Ἀΐδας ἕλοι πατρὶ ξυνθανεῖν γεραιῷ</tei:l>
                  <tei:l n="1690">τάλαιναν, ὡς ἔμοιγʼ ὁ μέλλων βίος οὐ βιωτός.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1691">ὦ διδύμα τέκνων ἀρίστα,</tei:l>
                  <tei:l n="1692">τὸ φέρον ἐκ θεοῦ φέρειν,</tei:l>
                  <tei:l n="1695">μηδὲν ἄγαν φλέγεσθον· οὔ τοι κατάμεμπτʼ ἔβητον.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1696"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1696">πόθος τοὶ καὶ κακῶν ἄρʼ ἦν τις.</tei:l>
                  <tei:l n="1700">καὶ γὰρ ὃ μηδαμὰ δὴ φίλον ἦν φίλον,</tei:l>
                  <tei:l n="1701">ὁπότε γε καὶ τὸν ἐν χεροῖν κατεῖχον.</tei:l>
                  <tei:l n="1702">ὦ πάτερ, ὦ φίλος,</tei:l>
                  <tei:l n="1703">ὦ τὸν ἀεὶ κατὰ γᾶς σκότον εἱμένος·</tei:l>
                  <tei:l n="1704">οὐδέ γʼ ἔνερθʼ ἀφίλητος ἐμοί ποτε</tei:l>
                  <tei:l n="1705">καὶ τᾷδε μὴ κυρήσῃς.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1706" part="I">ἔπραξεν;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1706a" part="F">ἔπραξεν οἷον ἤθελεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1707" part="I">τὸ ποῖον;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1707a" part="F">ἇς ἔχρῃζε γᾶς ἐπὶ ξένας</tei:l>
                  <tei:l n="1708">ἔθανε· κοίταν δʼ ἔχει</tei:l>
                  <tei:l n="1708a">νέρθεν εὐσκίαστον αἰέν,</tei:l>
                  <tei:l n="1709">οὐδὲ πένθος ἔλιπʼ ἄκλαυτον.</tei:l>
                  <tei:l n="1709a">ἀνὰ γὰρ ὄμμα σε τόδʼ, ὦ πάτερ, ἐμὸν</tei:l>
                  <tei:l n="1710">στένει δακρῦον, οὐδʼ ἔχω</tei:l>
                  <tei:l n="1711">πῶς με χρὴ τὸ σὸν τάλαιναν</tei:l>
                  <tei:l n="1712">ἀφανίσαι τοσόνδʼ ἄχος.</tei:l>
                  <tei:l n="1713">ὤμοι, γᾶς ἐπὶ ξένας θανεῖν ἔχρῃζες ἀλλʼ</tei:l>
                  <tei:l n="1714">ἔρημος ἔθανες ὧδέ μοι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1715">ὦ τάλαινα, τίς ἄρα με πότμος αὖθις ὧδʼ</tei:l>
                  <tei:l n="1716">
                     <tei:add>
                        <tei:gap reason="lost"/>
                     </tei:add>
                  </tei:l>
                  <tei:l n="1717">
                     <tei:add>
                        <tei:gap reason="lost"/>
                     </tei:add>
                  </tei:l>
                  <tei:l n="1719">ἐπαμμένει σέ τʼ, ὦ φίλα, τὰς πατρὸς ὧδʼ ἐρήμας;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1720">ἀλλʼ ἐπεὶ ὀλβίως γʼ ἔλυσεν</tei:l>
                  <tei:l n="1721">τὸ τέλος, ὦ φίλαι, βίου,</tei:l>
                  <tei:l n="1722">λήγετε τοῦδʼ ἄχους· κακῶν γὰρ δυσάλωτος οὐδείς.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1723"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1723" part="I">πάλιν, φίλα, συθῶμεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1723a" part="F">ὡς τί ῥέξομεν;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1724" part="I">ἵμερος ἔχει με.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1724a" part="F">τίς;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1725">τὰν χθόνιον ἑστίαν ἰδεῖν</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1726" part="I">τίνος;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1726a" part="F">πατρός, τάλαινʼ ἐγώ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1727">θέμις δὲ πῶς τάδʼ ἐστί; μῶν</tei:l>
                  <tei:l n="1728">οὐχ ὁρᾷς;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1730">τί τόδε ἐπέπληξας;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1731" part="I">καὶ τόδʼ, ὡς</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1731a" part="F">τί τόδε μάλʼ αὖθις;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1732">ἄταφος ἔπιτνε δίχα τε παντός.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1733">ἄγε με, καὶ τότʼ ἐπενάριξον.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἰσμήνη</tei:speaker>
                  <tei:l n="1734">αἰαῖ, δυστάλαινα, ποῦ δῆτʼ</tei:l>
                  <tei:l n="1735">αὖθις ὧδʼ ἔρημος ἄπορος</tei:l>
                  <tei:l n="1736">αἰῶνα τλάμονʼ ἕξω;</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1737"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1737" part="I">φίλαι, τρέσητε μηδέν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1737a" part="F">ἀλλὰ ποῖ φύγω;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1738" part="I">καὶ πάρος ἀπέφυγε</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1738a" part="F">τί;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1740">τὰ σφῷν τὸ μὴ πίτνειν κακῶς.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1741" part="I">φρονῶ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1741a" part="F">τί δῆθʼ ὅπερ νοεῖς;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1742">ὅπως μολούμεθʼ ἐς δόμους,</tei:l>
                  <tei:l n="1743" part="I">οὐκ ἔχω.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1743a" part="F">μηδέ γε μάτευε.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1744" part="I">μόγος ἔχει.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1744a" part="F">καὶ πάρος ἐπεῖχε.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1745" part="F">τοτὲ μὲν ἄπορα, τοτὲ δʼ ὕπερθεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1746">μέγʼ ἄρα πέλαγος ἐλάχετόν τι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1747" part="I">ναὶ ναί.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1747a" part="F">ξύμφημι καὐτός.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἀντιγόνη</tei:speaker>
                  <tei:l n="1748">αἰαῖ, ποῖ μόλωμεν, ὦ Ζεῦ;</tei:l>
                  <tei:l n="1749">ἐλπίδων γὰρ ἐς τίνʼ ἔτι με</tei:l>
                  <tei:l n="1750">δαίμων τανῦν γʼ ἐλαύνει;</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
