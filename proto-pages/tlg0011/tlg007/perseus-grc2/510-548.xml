<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:510-548" prev_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:254-509" next_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:549-667">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="510">δεινὸν μὲν τὸ πάλαι κείμενον ἤδη κακόν, ὦ ξεῖνʼ, ἐπεγείρειν·</tei:l>
                  <tei:l n="511">ὅμως δʼ ἔραμαι πυθέσθαι</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="512">τί τοῦτο;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="513">τᾶς δειλαίας ἀπόρου φανείσας</tei:l>
                  <tei:l n="514">ἀλγηδόνος, ᾇ ξυνέστας.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="515">μὴ πρὸς ξενίας ἀνοίξῃς</tei:l>
                  <tei:l n="516">τᾶς σᾶς ἃ πέπονθʼ ἀναιδῆ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="517">τό τοι πολὺ καὶ μηδαμὰ λῆγον</tei:l>
                  <tei:l n="518">χρῄζω, ξεῖνʼ, ὀρθὸν ἄκουσμʼ ἀκοῦσαι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="519">ὤμοι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="519a">στέρξον, ἱκετεύω.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="519b">φεῦ φεῦ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="520">πείθου· κἀγὼ γὰρ ὅσον σὺ προσχρῄζεις.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="521"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="521">ἤνεγκʼ οὖν κακότατʼ, ὦ ξένοι, ἤνεγκʼ ἀέκων μέν,</tei:l>
                  <tei:l n="522">θεὸς ἴστω,</tei:l>
                  <tei:l n="523">τούτων δʼ αὐθαίρετον οὐδέν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="524">ἀλλʼ ἐς τί;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="525">κακᾷ μʼ εὐνᾷ πόλις οὐδὲν ἴδριν</tei:l>
                  <tei:l n="526">γάμων ἐνέδησεν ἄτᾳ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="527">ἦ ματρόθεν, ὡς ἀκούω,</tei:l>
                  <tei:l n="528">δυσώνυμα λέκτρʼ ἐπλήσω;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="529">ὤμοι θάνατος μὲν τάδʼ ἀκούειν,</tei:l>
                  <tei:l n="530">ὦ ξεῖνʼ· αὗται δὲ δύʼ ἐξ ἐμοῦ μὲν</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="531">πῶς φῄς;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="532">παῖδε, δύο δʼ ἄτα</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="533">ὦ Ζεῦ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="534">ματρὸς κοινᾶς ἀπέβλαστον ὠδῖνος.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="535"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="535">σαί τʼ εἴσʼ ἄρʼ ἀπόγονοί τε καὶ </tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="536">κοιναί γε πατρὸς ἀδελφεαί.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="537" part="I">ἰώ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="537a" part="F">ἰὼ δῆτα μυρίων γʼ ἐπιστροφαὶ κακῶν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="538" part="I">ἔπαθες</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="538a" part="F">ἔπαθον ἄλαστʼ ἔχειν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="539" part="I">ἔρεξας</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="539a" part="M">οὐκ ἔρεξα.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="539b" part="M">τί γάρ;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="539c" part="F">ἐδεξάμην</tei:l>
                  <tei:l n="540">δῶρον, ὃ μήποτʼ ἐγὼ ταλακάρδιος</tei:l>
                  <tei:l n="541">ἐπωφέλησας πόλεος ἐξελέσθαι.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="542"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="542">δύστανε, τί γάρ; ἔθου φόνον</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="543">τί τοῦτο; τί δʼ ἐθέλεις μαθεῖν;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="544" part="I">πατρός;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="544a" part="F">παπαῖ. δευτέραν ἔπαισας, ἐπὶ νόσῳ νόσον,</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="545" part="I">ἔκανες</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="545a" part="F">ἔκανον. ἔχει δέ μοι</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="546" part="I">τί τοῦτο;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="546a" part="M">πρὸς δίκας τι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="546b" part="M">τί γάρ;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Οἰδίπους</tei:speaker>
                  <tei:l n="546c" part="F">ἐγὼ φράσω.</tei:l>
                  <tei:l n="547">καὶ γὰρ ἄν, οὓς ἐφόνευσʼ, ἔμʼ ἀπώλεσαν·</tei:l>
                  <tei:l n="548">νόμῳ δὲ καθαρός, ἄϊδρις εἰς τόδʼ ἦλθον.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
