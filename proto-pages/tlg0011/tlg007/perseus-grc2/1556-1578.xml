<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1556-1578" prev_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1500-1555" next_urn="urn:cts:greekLit:tlg0011.tlg007.perseus-grc2:1579-1669">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1556">εἰ θέμις ἐστί μοι τὰν ἀφανῆ θεὸν</tei:l>
                  <tei:l n="1557">καὶ σὲ λιταῖς σεβίζειν,</tei:l>
                  <tei:l n="1558">ἐννυχίων ἄναξ,</tei:l>
                  <tei:l n="1560">Αἰδωνεῦ Αἰδωνεῦ, λίσσωμαι</tei:l>
                  <tei:l n="1561">ἄπονα μήτʼ ἐπὶ βαρυαχεῖ</tei:l>
                  <tei:l n="1562">ξένον ἐξανύσαι</tei:l>
                  <tei:l n="1563">μόρῳ τὰν παγκευθῆ κάτω</tei:l>
                  <tei:l n="1564">νεκρῶν πλάκα καὶ Στύγιον δόμον.</tei:l>
                  <tei:l n="1565">πολλῶν γὰρ ἂν καὶ μάταν</tei:l>
                  <tei:l n="1566">πημάτων ἱκνουμένων</tei:l>
                  <tei:l n="1567">πάλιν σφε δαίμων δίκαιος αὔξοι.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1568"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1568">ὦ χθόνιαι θεαὶ σῶμά τʼ ἀνικάτου</tei:l>
                  <tei:l n="1569">θηρός, ὃν ἐν πύλαισι</tei:l>
                  <tei:l n="1570">ταῖσι πολυξένοις</tei:l>
                  <tei:l n="1571">εὐνᾶσθαι κνυζεῖσθαί τʼ ἐξ ἄντρων</tei:l>
                  <tei:l n="1572">ἀδάματον φύλακα παρʼ Ἁίδᾳ</tei:l>
                  <tei:l n="1573">λόγος αἰὲν ἔχει·</tei:l>
                  <tei:l n="1574">τόν, ὦ Γᾶς παῖ καὶ Ταρτάρου,</tei:l>
                  <tei:l n="1575">κατεύχομαι ἐν καθαρῷ βῆναι</tei:l>
                  <tei:l n="1576">ὁρμωμένῳ νερτέρας</tei:l>
                  <tei:l n="1577">τῷ ξένῳ νεκρῶν πλάκας·</tei:l>
                  <tei:l n="1578">σέ τοι κικλήσκω τὸν αἰένυπνον.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
