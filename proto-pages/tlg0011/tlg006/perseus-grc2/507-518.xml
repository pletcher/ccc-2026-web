<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg006.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg006.perseus-grc2:507-518" prev_urn="urn:cts:greekLit:tlg0011.tlg006.perseus-grc2:403-506" next_urn="urn:cts:greekLit:tlg0011.tlg006.perseus-grc2:519-675">
  <elements><tei:div type="choral">
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="507">οἴκτιρʼ, ἄναξ· πολλῶν ἔλεξεν δυσοίστων πόνων</tei:l>
                  <tei:l n="508">ἆθλʼ, οἷα μηδεὶς τῶν ἐμῶν τύχοι φίλων.</tei:l>
                  <tei:l n="510">εἰ δὲ πικρούς, ἄναξ, ἔχθεις Ἀτρείδας,</tei:l>
                  <tei:l n="511">ἐγὼ μέν, τὸ κείνων κακὸν τῷδε κέρδος</tei:l>
                  <tei:l n="515">μετατιθέμενος, ἔνθαπερ ἐπιμέμονεν,</tei:l>
                  <tei:l n="516">ἐπʼ εὐστόλου ταχείας νεὼς</tei:l>
                  <tei:l n="517">πορεύσαιμʼ ἂν ἐς δόμους, τὰν θεῶν</tei:l>
                  <tei:l n="518">νέμεσιν ἐκφυγών.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
