<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:693-717" prev_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:646-692" next_urn="urn:cts:greekLit:tlg0011.tlg003.perseus-grc2:719-878">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="693">ἔφριξʼ ἔρωτι, περιχαρὴς δʼ ἀνεπτόμαν.</tei:l>
                  <tei:l n="694">ἰὼ ἰὼ Πὰν Πάν,</tei:l>
                  <tei:l n="695">ὦ Πὰν Πὰν ἁλίπλαγκτε, Κυλλανίας χιονοκτύπου</tei:l>
                  <tei:l n="696">πετραίας ἀπὸ δειράδος φάνηθʼ, ὦ</tei:l>
                  <tei:l n="697">θεῶν χοροποίʼ ἄναξ, ὅπως μοι</tei:l>
                  <tei:l n="700">Νύσια Κνώσιʼ ὀρχήματʼ αὐτοδαῆ ξυνὼν ἰάψῃς·</tei:l>
                  <tei:l n="701">νῦν γὰρ ἐμοὶ μέλει χορεῦσαι.</tei:l>
                  <tei:l n="702">Ἰκαρίων δʼ ὑπὲρ πελαγέων μολὼν ἄναξ Ἀπόλλων</tei:l>
                  <tei:l n="705">ὁ Δάλιος εὔγνωστος</tei:l>
                  <tei:l n="706">ἐμοὶ ξυνείη διὰ παντὸς εὔφρων.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="707" resp="p"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="707">ἔλυσεν αἰνὸν ἄχος ἀπʼ ὀμμάτων Ἄρης.</tei:l>
                  <tei:l n="708">ἰὼ ἰώ, νῦν αὖ,</tei:l>
                  <tei:l n="709">νῦν, ὦ Ζεῦ, πάρα λευκὸν εὐάμερον πελάσαι φάος</tei:l>
                  <tei:l n="710">θοᾶν ὠκυάλων νεῶν, ὅτʼ Αἴας</tei:l>
                  <tei:l n="711">λαθίπονος πάλιν, θεῶν δʼ αὖ</tei:l>
                  <tei:l n="712">πάνθυτα θέσμιʼ ἐξήνυσʼ εὐνομίᾳ σέβων μεγίστᾳ.</tei:l>
                  <tei:l n="713">πάνθʼ ὁ μέγας χρόνος μαραίνει,</tei:l>
                  <tei:l n="715">κοὐδὲν ἀναύδατον φατίσαιμʼ ἄν, εὖτέ γʼ ἐξ ἀέλπτων</tei:l>
                  <tei:l n="716">Αἴας μετανεγνώσθη</tei:l>
                  <tei:l n="717">θυμοῦ τʼ Ἀτρείδαις μεγάλων τε νεικέων.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
