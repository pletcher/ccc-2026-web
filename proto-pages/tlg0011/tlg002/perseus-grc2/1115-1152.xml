<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg002.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg002.perseus-grc2:1115-1152" prev_urn="urn:cts:greekLit:tlg0011.tlg002.perseus-grc2:988-1114" next_urn="urn:cts:greekLit:tlg0011.tlg002.perseus-grc2:1155-1260">
  <elements><tei:div type="choral">
            <tei:milestone unit="card" n="1115"/>
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1115">πολυώνυμε, Καδμείας νύμφας ἄγαλμα</tei:l>
                  <tei:l n="1116">καὶ Διὸς βαρυβρεμέτα</tei:l>
                  <tei:l n="1117">γένος, κλυτὰν ὃς ἀμφέπεις</tei:l>
                  <tei:l n="1118">Ἰταλίαν, μέδεις δὲ</tei:l>
                  <tei:l n="1119">παγκοίνοις, Ἐλευσινίας</tei:l>
                  <tei:l n="1120">Δῃοῦς ἐν κόλποις, Βακχεῦ Βακχᾶν</tei:l>
                  <tei:l n="1121">ὁ ματρόπολιν Θήβαν</tei:l>
                  <tei:l n="1122">ναιετῶν παρʼ ὑγρῶν</tei:l>
                  <tei:l n="1125">Ἰσμηνοῦ ῥείθρων ἀγρίου τʼ ἐπὶ σπορᾷ δράκοντος.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1126"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1126">σὲ δʼ ὑπὲρ διλόφου πέτρας στέροψ ὄπωπε</tei:l>
                  <tei:l n="1127">λιγνύς, ἔνθα Κωρύκιαι</tei:l>
                  <tei:l n="1128">στείχουσι νύμφαι Βακχίδες,</tei:l>
                  <tei:l n="1130">Κασταλίας τε νᾶμα.</tei:l>
                  <tei:l n="1131">καί σε Νυσαίων ὀρέων</tei:l>
                  <tei:l n="1132">κισσήρεις ὄχθαι χλωρά τʼ ἀκτὰ</tei:l>
                  <tei:l n="1133">πολυστάφυλος πέμπει,</tei:l>
                  <tei:l n="1134">ἀμβρότων ἐπέων</tei:l>
                  <tei:l n="1135">εὐαζόντων Θηβαΐας ἐπισκοποῦντʼ ἀγυιάς·</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1137"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1137">τὰν ἐκ πᾶσαι τιμᾷς ὑπερτάταν πόλεων</tei:l>
                  <tei:l n="1138">ματρὶ σὺν κεραυνίᾳ·</tei:l>
                  <tei:l n="1140">καὶ νῦν, ὡς βιαίας ἔχεται</tei:l>
                  <tei:l n="1141">πάνδαμος πόλις ἐπὶ νόσου,</tei:l>
                  <tei:l n="1142">μολεῖν καθαρσίῳ ποδὶ Παρνασίαν ὑπὲρ κλιτὺν</tei:l>
                  <tei:l n="1145">ἢ στονόεντα πορθμόν.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1146"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1146">ἰὼ πῦρ πνειόντων χοράγʼ ἄστρων, νυχίων</tei:l>
                  <tei:l n="1147">φθεγμάτων ἐπίσκοπε,</tei:l>
                  <tei:l n="1148">παῖ Διὸς γένεθλον, προφάνηθʼ,</tei:l>
                  <tei:l n="1150">ὦναξ, σαῖς ἅμα περιπόλοις</tei:l>
                  <tei:l n="1151">Θυίαισιν, αἵ σε μαινόμεναι πάννυχοι χορεύουσι</tei:l>
                  <tei:l n="1152">τὸν ταμίαν Ἴακχον.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
