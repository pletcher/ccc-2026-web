<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0011.tlg005.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0011.tlg005.perseus-grc2:1384-1441" prev_urn="urn:cts:greekLit:tlg0011.tlg005.perseus-grc2:1288-1383" next_urn="urn:cts:greekLit:tlg0011.tlg005.perseus-grc2:1442-1510">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1384">ἴδεθʼ ὅποι προνέμεται</tei:l>
                  <tei:l n="1385">τὸ δυσέριστον αἷμα φυσῶν Ἄρης.</tei:l>
                  <tei:l n="1386">βεβᾶσιν ἄρτι δωμάτων ὑπόστεγοι</tei:l>
                  <tei:l n="1387">μετάδρομοι κακῶν πανουργημάτων ἄφυκτοι κύνες,</tei:l>
                  <tei:l n="1388">ὥστʼ οὐ μακρὰν ἔτʼ ἀμμενεῖ</tei:l>
                  <tei:l n="1390">τοὐμὸν φρενῶν ὄνειρον αἰωρούμενον.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1391"/>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1391">παράγεται γὰρ ἐνέρων</tei:l>
                  <tei:l n="1392">δολιόπους ἀρωγὸς εἴσω στέγας,</tei:l>
                  <tei:l n="1393">ἀρχαιόπλουτα πατρὸς εἰς ἑδώλια,</tei:l>
                  <tei:l n="1394">νεακόνητον αἷμα χειροῖν ἔχων· ὁ Μαίας δὲ παῖς</tei:l>
                  <tei:l n="1395">Ἑρμῆς σφʼ ἄγει δόλον σκότῳ</tei:l>
                  <tei:l n="1396">κρύψας πρὸς αὐτὸ τέρμα κοὐκέτʼ ἀμμένει.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1397"/>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1397">ὦ φίλταται γυναῖκες, ἅνδρες αὐτίκα</tei:l>
                  <tei:l n="1398">τελοῦσι τοὔργον· ἀλλὰ σῖγα πρόσμενε.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1399">πῶς δή; τί νῦν πράσσουσιν;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1400">ἡ μὲν ἐς τάφον</tei:l>
                  <tei:l n="1401">λέβητα κοσμεῖ, τὼ δʼ ἐφέστατον πέλας.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1402" part="I">σὺ δʼ ἐκτὸς ᾖξας πρὸς τί;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1402a" part="F">φρουρήσουσʼ ὅπως</tei:l>
                  <tei:l n="1403">Αἴγισθος ἡμᾶς μὴ λάθῃ μολὼν ἔσω.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Κλυταιμνήστρα</tei:speaker>
                  <tei:l n="1404">αἰαῖ. ἰὼ στέγαι</tei:l>
                  <tei:l n="1405">φίλων ἔρημοι, τῶν δʼ ἀπολλύντων πλέαι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1406">βοᾷ τις ἔνδον· οὐκ ἀκούετʼ, ὦ φίλαι;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1407">ἤκουσʼ ἀνήκουστα δύστανος, ὥστε φρῖξαι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Κλυταιμνήστρα</tei:speaker>
                  <tei:l n="1408">οἴμοι τάλαινʼ· Αἴγισθε, ποῦ ποτʼ ὢν κυρεῖς;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1409">ἰδοὺ μάλʼ αὖ θροεῖ τις.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Κλυταιμνήστρα</tei:speaker>
                  <tei:l n="1410">ὦ τέκνον τέκνον, οἴκτιρε τὴν τεκοῦσαν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1411">ἀλλʼ οὐκ ἐκ σέθεν</tei:l>
                  <tei:l n="1412">ᾠκτίρεθʼ οὗτος οὐδʼ ὁ γεννήσας πατήρ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1413">ὦ πόλις, ὦ γενεὰ τάλαινα, νῦν σοι</tei:l>
                  <tei:l n="1414">μοῖρα καθαμερία φθίνει φθίνει.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Κλυταιμνήστρα</tei:speaker>
                  <tei:l n="1415">ὤμοι πέπληγμαι.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1416">παῖσον, εἰ σθένεις, διπλῆν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Κλυταιμνήστρα</tei:speaker>
                  <tei:l n="1417">ὤμοι μάλʼ αὖθις.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1418">εἰ γὰρ Αἰγίσθῳ θʼ ὁμοῦ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1419">τελοῦσʼ ἀραί· ζῶσιν οἱ γᾶς ὑπαὶ κείμενοι.</tei:l>
                  <tei:l n="1420">παλίρρυτον γὰρ αἷμʼ ὑπεξαιροῦσι τῶν</tei:l>
                  <tei:l n="1421">κτανόντων οἱ πάλαι θανόντες.</tei:l>
               </tei:sp>
            </tei:div>
            <tei:milestone unit="card" n="1422"/>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1422">καὶ μὴν πάρεισιν οἵδε· φοινία δὲ χεὶρ</tei:l>
                  <tei:l n="1423">στάζει θυηλῆς Ἄρεος, οὐδʼ ἔχω ψέγειν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1424" part="I">Ὀρέστα, πῶς κυρεῖτε;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ὀρέστης</tei:speaker>
                  <tei:l n="1424a" part="F">τἀν δόμοισι μὲν</tei:l>
                  <tei:l n="1425">καλῶς, Ἀπόλλων εἰ καλῶς ἐθέσπισεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1426">τέθνηκεν ἡ τάλαινα;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ὀρέστης</tei:speaker>
                  <tei:l n="1427">μηκέτʼ ἐκφοβοῦ</tei:l>
                  <tei:l n="1428">μητρῷον ὥς σε λῆμʼ ἀτιμάσει ποτέ.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1429">παύσασθε· λεύσσω γὰρ Αἴγισθον ἐκ προδήλου.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1430">ὦ παῖδες, οὐκ ἄψορρον;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ὀρέστης</tei:speaker>
                  <tei:l n="1431">εἰσορᾶτε ποῦ τὸν ἄνδρʼ;</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1432">ἐφʼ ἡμῖν οὗτος ἐκ προαστίου</tei:l>
                  <tei:l n="1433">χωρεῖ γεγηθὼς<tei:gap reason="lost"/>
                  </tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1434">βᾶτε κατʼ ἀντιθύρων ὅσον τάχιστα,</tei:l>
                  <tei:l n="1435">νῦν, τὰ πρὶν εὖ θέμενοι, τάδʼ ὡς πάλιν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ὀρέστης</tei:speaker>
                  <tei:l n="1436">θάρσει· τελοῦμεν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1437">ᾗ νοεῖς ἔπειγέ νυν.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ὀρέστης</tei:speaker>
                  <tei:l n="1438" part="I">καὶ δὴ βέβηκα.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Ἠλέκτρα</tei:speaker>
                  <tei:l n="1438a" part="F">τἀνθάδʼ ἂν μέλοιτʼ ἐμοί.</tei:l>
               </tei:sp>
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l n="1439">διʼ ὠτὸς ἂν παῦρά γʼ ὡς ἠπίως ἐννέπειν</tei:l>
                  <tei:l n="1440">πρὸς ἄνδρα τόνδε συμφέροι, λαθραῖον ὡς</tei:l>
                  <tei:l n="1441">ὀρούσῃ πρὸς δίκας ἀγῶνα.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
