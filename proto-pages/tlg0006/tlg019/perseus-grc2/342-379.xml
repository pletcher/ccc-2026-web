<?xml version='1.0' encoding='utf-8'?>
<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0006.tlg019.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0006.tlg019.perseus-grc2:342-379" prev_urn="urn:cts:greekLit:tlg0006.tlg019.perseus-grc2:264-341" next_urn="urn:cts:greekLit:tlg0006.tlg019.perseus-grc2:380-526">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="342">Ἀδράστεια μὲν ἁ Διὸς</tei:l>
                  <tei:l n="343">παῖς εἴργοι στομάτων φθόνον·</tei:l>
                  <tei:l n="344">φράσω γὰρ δὴ ὅσον μοι ψυχᾷ</tei:l>
                  <tei:l n="345">προσφιλές ἐστιν εἰπεῖν.</tei:l>
                  <tei:l n="346">ἥκεις, ὦ ποταμοῦ παῖ,</tei:l>
                  <tei:l n="347">ἥκεις, ἐπλάθης Φιλίου πρὸς αὐλὰν</tei:l>
                  <tei:l n="348">ἀσπαστός, ἐπεί σε χρόνῳ</tei:l>
                  <tei:l n="349">Πιερὶς μάτηρ ὅ τε καλλιγέφυ-</tei:l>
                  <tei:l n="350">ρος ποταμὸς πορεύει</tei:l>
               </tei:sp>
               <tei:milestone resp="perseus" unit="card" n="351"/>
            </tei:div>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="351">Στρυμών, ὅς ποτε τᾶς μελῳ-</tei:l>
                  <tei:l n="352">δοῦ Μούσας διʼ ἀκηράτων</tei:l>
                  <tei:l n="353">δινηθεὶς ὑδροειδὴς κόλπων</tei:l>
                  <tei:l n="354">σὰν ἐφύτευσεν ἥβαν.</tei:l>
                  <tei:l n="355">σύ μοι Ζεὺς ὁ φαναῖος</tei:l>
                  <tei:l n="356">ἥκεις διφρεύων βαλιαῖσι πώλοις.</tei:l>
                  <tei:l n="357">νῦν, ὦ πατρὶς ὦ Φρυγία,</tei:l>
                  <tei:l n="358">ξὺν θεῷ νῦν σοι τὸν ἐλευθέριον</tei:l>
                  <tei:l n="359">Ζῆνα πάρεστιν εἰπεῖν.</tei:l>
               </tei:sp>
               <tei:milestone resp="perseus" unit="card" n="360"/>
            </tei:div>
            <tei:div n="2" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="360">ἆρά ποτʼ αὖθις ἁ παλαιὰ Τροΐα</tei:l>
                  <tei:l n="361">τοὺς προπότας παναμερεύ-</tei:l>
                  <tei:l n="362">σει θιάσους ἐρώτων</tei:l>
                  <tei:l n="363">ψαλμοῖσι καὶ κυλίκων οἰνοπλανή-</tei:l>
                  <tei:l n="364">τοις ὑποδεξίαις ἁμίλ-</tei:l>
                  <tei:l n="365">λαις κατὰ πόντον Ἀτρειδᾶν</tei:l>
                  <tei:l n="366">Σπάρταν οἰχομένων</tei:l>
                  <tei:l n="366a">Ἰλιάδος παρʼ ἀκτᾶς;</tei:l>
                  <tei:l n="367">ὦ φίλος, εἴθε μοι</tei:l>
                  <tei:l n="368">σᾷ χερὶ καὶ σῷ δορὶ πρά-</tei:l>
                  <tei:l n="369">ξας τάδʼ ἐς οἶκον ἔλθοις.</tei:l>
               </tei:sp>
               <tei:milestone resp="perseus" unit="card" n="370"/>
            </tei:div>
            <tei:div n="2" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="370">ἐλθέ, φάνηθι, τὰν ζάχρυσον προβαλοῦ</tei:l>
                  <tei:l n="371">Πηλεΐδα κατʼ ὄμμα πέλ-</tei:l>
                  <tei:l n="372">ταν δοχμίαν πεδαίρων</tei:l>
                  <tei:l n="373">σχιστὰν παρʼ ἄντυγα, πώλους ἐρεθί-</tei:l>
                  <tei:l n="374">ζων δίβολόν τʼ ἄκοντα πάλ-</tei:l>
                  <tei:l n="375">λων. σὲ γὰρ οὔτις ὑποστὰς</tei:l>
                  <tei:l n="376">Ἀργείας ποτʼ ἐν Ἥ-</tei:l>
                  <tei:l n="377">ρας δαπέδοις χορεύσει·</tei:l>
                  <tei:l n="378">ἀλλά νιν ἅδε γᾶ</tei:l>
                  <tei:l n="378a">καπφθίμενον Θρῃκὶ μόρῳ</tei:l>
                  <tei:l n="379">φίλτατον ἄχθος οἴσει.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
