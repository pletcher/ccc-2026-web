<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0006.tlg016.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0006.tlg016.perseus-grc2:1353-1365" prev_urn="urn:cts:greekLit:tlg0006.tlg016.perseus-grc2:1286-1352" next_urn="urn:cts:greekLit:tlg0006.tlg016.perseus-grc2:1366-1536">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="1353">— ἰὼ ἰὼ φίλαι,</tei:l>
                  <tei:l n="1353a">κτύπον ἐγείρετε, κτύπον καὶ βοὰν</tei:l>
                  <tei:l n="1354">πρὸ μελάθρων, ὅπως ὁ πραχθεὶς φόνος</tei:l>
                  <tei:l n="1355">μὴ δεινὸν Ἀργείοισιν ἐμβάλῃ φόβον,</tei:l>
                  <tei:l n="1356">βοηδρομῆσαι πρὸς δόμους τυραννικούς,</tei:l>
                  <tei:l n="1357">πρὶν ἐτύμως ἴδω τὸν Ἑλένας φόνον</tei:l>
                  <tei:l n="1358">καθαιμακτὸν ἐν δόμοις κείμενον,</tei:l>
                  <tei:l n="1359">ἢ καὶ λόγον του προσπόλων πυθώμεθα·</tei:l>
                  <tei:l n="1360">τὰ μὲν γὰρ οἶδα συμφορᾶς, τὰ δʼ οὐ σαφῶς.</tei:l>
                  <tei:l n="1361">— διὰ δίκας ἔβα θεῶν</tei:l>
                  <tei:l n="1362">νέμεσις ἐς Ἑλέναν.</tei:l>
                  <tei:l n="1363">δακρύοισι γὰρ Ἑλλάδʼ ἅπασαν ἔπλησε,</tei:l>
                  <tei:l n="1364">διὰ τὸν ὀλόμενον ὀλόμενον Ἰδαῖον</tei:l>
                  <tei:l n="1365">Πάριν, ὃς ἄγαγʼ Ἑλλάδʼ εἰς Ἴλιον.</tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
