<citationChunk xmlns:tei="http://www.tei-c.org/ns/1.0" unit="scene" base_urn="urn:cts:greekLit:tlg0006.tlg018.perseus-grc2" cts_urn="urn:cts:greekLit:tlg0006.tlg018.perseus-grc2:543-589" prev_urn="urn:cts:greekLit:tlg0006.tlg018.perseus-grc2:303-542" next_urn="urn:cts:greekLit:tlg0006.tlg018.perseus-grc2:590-750">
  <elements><tei:div type="choral">
            <tei:div n="1" type="strophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="543">—μάκαρες οἳ μετρίας θεοῦ</tei:l>
                  <tei:l n="544">μετά τε σωφροσύνας μετέ-</tei:l>
                  <tei:l n="545">σχον λέκτρων Ἀφροδίτας,</tei:l>
                  <tei:l n="546">γαλανείᾳ χρησάμενοι</tei:l>
                  <tei:l n="547">μανιάδων οἴστρων, ὅθι δὴ</tei:l>
                  <tei:l n="548">δίδυμʼ Ἔρως ὁ χρυσοκόμας</tei:l>
                  <tei:l n="549">τόξʼ ἐντείνεται χαρίτων,</tei:l>
                  <tei:l n="550">τὸ μὲν ἐπʼ εὐαίωνι πότμῳ,</tei:l>
                  <tei:l n="551">τὸ δʼ ἐπὶ συγχύσει βιοτᾶς.</tei:l>
                  <tei:l n="552">ἀπενέπω νιν ἁμετέρων,</tei:l>
                  <tei:l n="553">Κύπρι καλλίστα, θαλάμων.</tei:l>
                  <tei:l n="554">εἴη δέ μοι μετρία μὲν</tei:l>
                  <tei:l n="555">χάρις, πόθοι δʼ ὅσιοι,</tei:l>
                  <tei:l n="556">καὶ μετέχοιμι τᾶς Ἀφροδί-</tei:l>
                  <tei:l n="557">τας, πολλὰν δʼ ἀποθείμαν.</tei:l>
               </tei:sp>
               <tei:milestone resp="perseus" unit="card" n="558"/>
            </tei:div>
            <tei:div n="1" type="antistrophe">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="558">—διάφοροι δὲ φύσεις βροτῶν,</tei:l>
                  <tei:l n="559">διάφοροι δὲ τρόποι· τὸ δʼ ὀρ-</tei:l>
                  <tei:l n="560">θῶς ἐσθλὸν σαφὲς αἰεί·</tei:l>
                  <tei:l n="561">τροφαί θʼ αἱ παιδευόμεναι</tei:l>
                  <tei:l n="562">μέγα φέρουσʼ ἐς τὰν ἀρετάν·</tei:l>
                  <tei:l n="563">τό τε γὰρ αἰδεῖσθαι σοφία,</tei:l>
                  <tei:l n="564">τάν τʼ ἐξαλλάσσουσαν ἔχει</tei:l>
                  <tei:l n="565">χάριν ὑπὸ γνώμας ἐσορᾶν</tei:l>
                  <tei:l n="566">τὸ δέον, ἔνθα δόξα φέρει</tei:l>
                  <tei:l n="567">κλέος ἀγήρατον βιοτᾷ.</tei:l>
                  <tei:l n="568">μέγα τι θηρεύειν ἀρετάν,</tei:l>
                  <tei:l n="569">γυναιξὶ μὲν κατὰ Κύπριν</tei:l>
                  <tei:l n="570">κρυπτάν, ἐν ἀνδράσι δʼ αὖ</tei:l>
                  <tei:l n="571">κόσμος ἐνὼν ὁ μυριοπλη-</tei:l>
                  <tei:l n="572">θὴς μείζω πόλιν αὔξει.</tei:l>
               </tei:sp>
               <tei:milestone resp="perseus" unit="card" n="573"/>
            </tei:div>
            <tei:div type="epode">
               <tei:sp>
                  <tei:speaker>Χορός</tei:speaker>
                  <tei:l rend="indent" n="573">—ἔμολες, ὦ Πάρις, ᾗτε σύ γε</tei:l>
                  <tei:l n="574">βουκόλος ἀργενναῖς ἐτράφης</tei:l>
                  <tei:l n="575">Ἰδαίαις παρὰ μόσχοις,</tei:l>
                  <tei:l n="576">βάρβαρα συρίζων, Φρυγίων</tei:l>
                  <tei:l n="577">αὐλῶν Ὀλύμπου καλάμοις</tei:l>
                  <tei:l n="578">μιμήματα πνείων.</tei:l>
                  <tei:l n="579">εὔθηλοι δὲ τρέφοντο βόες,</tei:l>
                  <tei:l n="580">ὅτε σε κρίσις ἔμηνε θεᾶν,</tei:l>
                  <tei:l n="581">ἅ σʼ Ἑλλάδα πέμπει·</tei:l>
                  <tei:l n="582">ἐλεφαντοδέτων πάροι-</tei:l>
                  <tei:l n="583">θεν δόμων δὲ στὰς Ἑλένας</tei:l>
                  <tei:l n="584">ἐν ἀντωποῖς βλεφάροισιν</tei:l>
                  <tei:l n="585">ἔρωτά τʼ ἔδωκας, ἔρωτι δʼ</tei:l>
                  <tei:l n="586">αὐτὸς ἐπτοάθης.</tei:l>
                  <tei:l n="587">ὅθεν ἔρις ἔριν</tei:l>
                  <tei:l n="588">Ἑλλάδα σὺν δορὶ ναυσί τʼ ἄγει</tei:l>
                  <tei:l n="589">
                     <tei:del>ἐς</tei:del> Τροίας πέργαμα <tei:gap reason="lost" rend=". . . . . . "/>
                  </tei:l>
               </tei:sp>
            </tei:div>
         </tei:div>
         </elements>
</citationChunk>
