{% extends "base.html.jinja" %}

{% block title %}{{ pub_info.author }}, {{ chunk.title }}, {{ chunk.cts_urn.rsplit(':', 1)[-1] }}{% endblock %}

{% block header %}
    <header class="hero mb-4">
        <div class="px-8 text-base-content w-full">
            <div>
                <h1 class="text-xl font-bold">
                    {{ pub_info.author }} <em>{{ chunk.title }}</em>
                </h1>
                {% if pub_info.editors %}
                    <h2 class="text-lg font-bold">{{ pub_info.editors | join(", ") }}</h2>
                {% endif %}
            </div>
        </div>
    </header>
{% endblock %}

{% block content %}
    <main class="flex pt-4 w-full items-start">
        <!-- Left nav: sticky + self-contained height so TOC open/close doesn't shift the page -->
        <div class="text-base-content text-xs w-1/5 sticky top-0 self-start max-h-screen overflow-y-auto">
            <div class="bg-base-400 p-4 mb-4">
                <h3 class="font-bold">Table of Contents:</h3>
                <ul class="menu [&_li>*]:rounded-none flex-nowrap w-full">
                    {% for nav_item in toc.get("table_of_contents", []) %}
                      {% with item = nav_item %}
                        {% include 'components/NavigationItem.html.jinja' %}
                      {% endwith %}
                    {% endfor %}
                </ul>
            </div>
        </div>

        <!-- Base text -->
        <article class="w-3/5 mx-4 text-sm">
            <div class="flex justify-between mb-4 text-xs">
                {% if prev_url %}
                    <a href="{{ prev_url }}" class="link">&larr; Previous</a>
                {% else %}
                    <span></span>
                {% endif %}
                {% if next_url %}
                    <a href="{{ next_url }}" class="link">Next &rarr;</a>
                {% endif %}
            </div>

            <div class="prose">
                {% set notes = namespace(items=[]) %}
                {% for element in chunk.elements %}
                    {% with text_container = element %}
                        {%  include 'components/ReadableTextContainer.html.jinja' %}
                    {% endwith %}
                {% endfor %}
            </div>

            <div class="pt-8">
                <p class="mb-4">
                    {{ chunk.title }}.
                    {{ pub_info.author }}.
                    {% if pub_info.editors %}{{ pub_info.editors | join(", ") }}.{% endif %}
                    {{ pub_info.pub_place }}.
                    {{ pub_info.pub_date }}.
                </p>
                <p class="mb-4">Tufts University provided support for entering this text.</p>
                <p>
                    This text was converted to electronic form by professional
                    data entry and has been proofread to a medium level of
                    accuracy.
                </p>
            </div>
        </article>
    </main>

    {% for note in notes.items %}
        <dialog id="{{ note.id }}" class="tei-note-dialog rounded p-4 shadow-lg max-w-prose w-full mt-16 mx-auto backdrop:bg-black/40">
            <form method="dialog" class="flex justify-end mb-2">
                <button type="submit" class="cursor-pointer font-bold text-lg leading-none" aria-label="Close">&#215;</button>
            </form>
            <div class="tei-note-content text-sm prose">
                {{ note.content }}
            </div>
        </dialog>
    {% endfor %}

    <footer class="text-xs bg-neutral-300 p-4 bottom-0">
        <div class="rights_info">
            <div class="cc_rights flex items-start gap-4 mb-2">
                <a rel="license" href="https://creativecommons.org/licenses/by-sa/3.0/us/">
                    <img
                        alt="Creative Commons License"
                        style="border-width: 0"
                        src="https://i.creativecommons.org/l/by-sa/3.0/us/88x31.png"
                    />
                </a>
                <p>
                    This work is licensed under a
                    <a rel="license" href="https://creativecommons.org/licenses/by-sa/3.0/us/">
                        Creative Commons Attribution-ShareAlike 3.0 United States License
                    </a>.
                </p>
            </div>
            <p class="xml_download">
                An <a href="{{ xml_src_url }}">XML version</a>
                of this text is available for download, with the additional restriction
                that you offer Perseus any modifications you make. Perseus provides
                credit for all accepted changes, storing new additions in a versioning
                system.
            </p>
        </div>
    </footer>
{% endblock %}

{% block scripts %}
<script>
(function() {
    const lineEls = document.querySelectorAll(".tei-token")

    lineEls.forEach(line => {
        const heat = line.dataset.heat;
        let bgColor = "bg-primary-50";
        let magnitude = 0;

        // this looks gross, but it's so that the CSS
        // compiler can pick out the colors that might
        // be used, rather than throwing the classes away
        if (heat < -0.9) {
            bgColor = "bg-blue-900";
            magnitude = 900;
        } else if (heat < -0.8) {
            bgColor = "bg-blue-800";
            magnitude = 800;
        } else if (heat < -0.7) {
            bgColor = "bg-blue-700";
            magnitude = 700;
        } else if (heat < -0.6) {
            bgColor = "bg-blue-600";
            magnitude = 600;
        } else if (heat < -0.5) {
            bgColor = "bg-blue-500";
            magnitude = 500;
        } else if (heat < -0.4) {
            bgColor = "bg-blue-400";
            magnitude = 400;
        } else if (heat < -0.3) {
            bgColor = "bg-blue-300";
            magnitude = 300;
        } else if (heat < -0.2) {
            bgColor = "bg-blue-200";
            magnitude = 200;
        } else if (heat < -0.1) {
            bgColor = "bg-blue-100";
            magnitude = 100;
        } else if (heat > 0.1) {
            bgColor = "bg-red-100";
            magnitude = 100;
        } else if (heat > 0.2) {
            bgColor = "bg-red-200";
            magnitude = 200;
        } else if (heat > 0.3) {
            bgColor = "bg-red-300";
            magnitude = 300;
        } else if (heat > 0.4) {
            bgColor = "bg-red-400";
            magnitude = 400;
        } else if (heat > 0.5) {
            bgColor = "bg-red-500";
            magnitude = 500;
        } else if (heat > 0.6) {
            bgColor = "bg-red-600";
            magnitude = 600;
        } else if (heat > 0.7) {
            bgColor = "bg-red-700";
            magnitude = 700;
        } else if (heat > 0.8) {
            bgColor = "bg-red-800";
            magnitude = 800;
        } else if (heat > 0.9) {
            bgColor = "bg-red-900";
            magnitude = 900;
        }

        if (magnitude > 600) {
            line.classList.add("text-base-100")
        }

        line.classList.add("inline-block");
        line.classList.add(bgColor);
    });
})()
</script>
{% endblock %}

